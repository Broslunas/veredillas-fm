---
interface Props {
  slug: string;
}

const { slug } = Astro.props;

import { verifyToken } from '../lib/auth';
import dbConnect from '../lib/mongodb';
import User from '../models/User';

// Safe serializable user object for the client
let currentUserSafe: { name: string; role: string; picture?: string } | null = null;
try {
    const token = Astro.cookies.get('auth-token')?.value;
    if (token) {
        const payload = verifyToken(token);
        if (payload) {
             await dbConnect();
             const dbUser = await User.findById(payload.userId).select('name role picture').lean();
             if (dbUser) {
                 currentUserSafe = {
                     name: dbUser.name,
                     role: dbUser.role as string,
                     picture: dbUser.picture
                 };
             }
        }
    }
} catch(e) {
    console.error('[LiveChat] Auth helper error', e);
}

// Encode safely to avoid HTML attribute issues with quotes
const currentUserEncoded = currentUserSafe ? btoa(unescape(encodeURIComponent(JSON.stringify(currentUserSafe)))) : '';
---

<div class="live-chat-container" id="live-chat-widget" data-slug={slug} data-current-user={currentUserEncoded}>
    <div class="chat-header">
        <div class="live-indicator">
            <span class="dot"></span> EN DIRECTO
        </div>
        <h3>Chat de Estreno</h3>
    </div>
    
    <div class="messages-area" id="chat-messages">
        <div id="pinned-message-container" style="display: none;"></div>
        <div class="system-message">Bienvenido al chat en directo. Sé respetuoso.</div>
        <!-- Messages injected here -->
    </div>

    <div class="input-area">
        {(!currentUserSafe) && (
            <input type="text" id="guest-name-input" placeholder="Tu nombre..." class="guest-input" autocomplete="off" />
        )}
        <div class="input-row">
            <input type="text" id="chat-input" placeholder={currentUserSafe ? `Escribe como ${currentUserSafe.name}...` : "Escribe un mensaje..."} autocomplete="off" />
            <button id="send-btn" type="button" aria-label="Enviar">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 2L11 13M22 2L15 22L11 13L2 9L22 2Z" />
                </svg>
            </button>
        </div>
        <div class="reactions-bar">
            <button class="reaction-btn" data-type="heart">❤️</button>
            <button class="reaction-btn" data-type="fire">🔥</button>
            <button class="reaction-btn" data-type="clap">👏</button>
            <button class="reaction-btn" data-type="100">💯</button>
        </div>
        
        <div id="reactions-container"></div>
        <div id="live-chat-toast" class="toast hidden"></div>
        <div id="live-chat-confirm" class="confirm-modal hidden">
             <div class="confirm-content">
                 <p id="confirm-text"></p>
                 <div class="confirm-actions">
                     <button id="confirm-cancel" class="btn-cancel">Cancelar</button>
                     <button id="confirm-ok" class="btn-ok">Confirmar</button>
                 </div>
             </div>
        </div>
    </div>
</div>

<style>
    .live-chat-container {
        display: flex;
        flex-direction: column;
        height: 500px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
    }

    .chat-header {
        padding: var(--spacing-sm) var(--spacing-md);
        background: rgba(0,0,0,0.2);
        border-bottom: 1px solid var(--color-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .live-indicator {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.7rem;
        font-weight: bold;
        color: #ef4444;
        background: rgba(239, 68, 68, 0.1);
        padding: 2px 8px;
        border-radius: 12px;
    }

    .dot {
        width: 6px;
        height: 6px;
        background: #ef4444;
        border-radius: 50%;
        animation: pulse-red 1.5s infinite;
    }

    .chat-header h3 {
        font-size: 0.9rem;
        margin: 0;
        color: var(--color-text-muted);
    }

    .messages-area {
        flex: 1;
        overflow-y: auto;
        padding: var(--spacing-md);
        display: flex;
        flex-direction: column;
        gap: 12px;
        scroll-behavior: smooth;
    }

    .system-message {
        text-align: center;
        font-size: 0.8rem;
        color: var(--color-text-muted);
        opacity: 0.7;
        margin-bottom: 10px;
    }

    .input-area {
        padding: var(--spacing-md);
        background: rgba(0,0,0,0.2);
        border-top: 1px solid var(--color-border);
    }

    .guest-input {
        width: 100%;
        margin-bottom: 8px;
        padding: 8px 12px;
        border-radius: 6px;
        border: 1px solid var(--color-border);
        background: rgba(0,0,0,0.2);
        color: var(--color-text-main);
        font-size: 0.9rem;
    }

    .input-row {
        display: flex;
        gap: 8px;
    }

    #chat-input {
        flex: 1;
        padding: 8px 12px;
        border-radius: 20px;
        border: 1px solid var(--color-border);
        background: rgba(0,0,0,0.2);
        color: var(--color-text-main);
        font-size: 0.9rem;
    }
    
    #chat-input:focus, .guest-input:focus {
        border-color: var(--color-primary);
        outline: none;
    }

    #send-btn {
        background: var(--color-primary);
        color: white;
        border: none;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: transform 0.2s;
    }

    #send-btn:hover {
        transform: scale(1.1);
    }
    
    .reactions-bar {
        display: flex;
        justify-content: center;
        gap: 10px;
        padding: 5px 0;
        margin-top: 10px;
    }
    
    .reaction-btn {
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 20px;
        width: 36px;
        height: 36px;
        font-size: 1.2rem;
        cursor: pointer;
        transition: transform 0.1s, background 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
    }
    :global(.admin-actions) {
        margin-left: auto;
        display: flex;
        gap: 6px;
    }
    
    :global(.ban-btn) {
        background: rgba(234, 179, 8, 0.2);
        border: 1px solid rgba(234, 179, 8, 0.5);
        color: #eab308; /* Yellow-500 */
        width: 24px;
        height: 24px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        padding: 4px;
        transition: all 0.2s ease;
        opacity: 1;
    }
    
    :global(.ban-btn:hover) {
        background: #eab308;
        color: white;
        border-color: #eab308;
        transform: scale(1.1);
    }
    :global(.ban-btn svg) {
        width: 100%;
        height: 100%;
        display: block;
    }
    
    :global(.delete-btn) {
        background: rgba(239, 68, 68, 0.2);
        border: 1px solid rgba(239, 68, 68, 0.5);
        color: #ef4444;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        padding: 4px;
        /* Removed margin-left auto as it is now in flex container */
        transition: all 0.2s ease;
        opacity: 1;
    }
    :global(.delete-btn:hover) {
        background: #ef4444;
        color: white;
        border-color: #ef4444;
        transform: scale(1.1);
    }
    :global(.delete-btn svg) {
        width: 100%;
        height: 100%;
        display: block;
    }
    
    .reaction-btn:hover {
        background: rgba(255,255,255,0.2);
        transform: scale(1.1);
    }
    
    .reaction-btn:active {
        transform: scale(0.9);
    }

    #reactions-container {
        position: fixed;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        z-index: 9999; /* Top level */
    }

    /* TOAST STYLES */
    .toast {
        position: fixed;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(30, 41, 59, 0.95);
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        font-size: 0.9rem;
        z-index: 1000;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: opacity 0.3s ease, transform 0.3s ease;
        opacity: 0;
        pointer-events: none;
    }
    
    .toast.visible {
        opacity: 1;
        pointer-events: auto;
        transform: translateX(-50%) translateY(0);
    }
    
    .toast.error {
        border-left: 3px solid #ef4444;
    }
    .toast.success {
        border-left: 3px solid #10b981;
    }
    
    .hidden {
        display: none !important;
    }

    /* CONFIRM MODAL STYLES */
    :global(.confirm-modal) {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2000;
        backdrop-filter: blur(2px);
    }
    
    :global(.confirm-content) {
        background: var(--color-surface);
        padding: 20px;
        border-radius: 12px;
        border: 1px solid var(--color-border);
        width: 80%;
        max-width: 300px;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
        text-align: center;
    }
    
    :global(#confirm-text) {
        margin-bottom: 20px;
        font-size: 0.95rem;
        color: var(--color-text-main);
    }
    
    :global(.confirm-actions) {
        display: flex;
        gap: 10px;
        justify-content: center;
    }
    
    :global(.btn-cancel), :global(.btn-ok) {
        padding: 6px 16px;
        border-radius: 6px;
        font-size: 0.9rem;
        cursor: pointer;
        border: none;
        font-weight: 500;
    }
    
    :global(.btn-cancel) {
        background: rgba(255, 255, 255, 0.1);
        color: var(--color-text-main);
    }
    
    :global(.btn-ok) {
        background: var(--color-primary);
        color: white;
    }
    
    :global(.btn-cancel:hover) {
        background: rgba(255, 255, 255, 0.2);
    }
    
    :global(.btn-ok:hover) {
        opacity: 0.9;
    }

    :global(.pinned-message) {
        background: rgba(var(--color-primary-rgb), 0.1);
        border-left: 3px solid var(--color-primary);
        padding: 8px 12px;
        margin-bottom: 10px;
        border-radius: 4px;
        font-size: 0.9rem;
        display: flex;
        align-items: flex-start;
        gap: 8px;
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(5px);
    }
    
    :global(.pinned-icon) {
        color: var(--color-primary);
        flex-shrink: 0;
        margin-top: 2px;
    }

    :global(.pinned-content) {
        flex: 1;
    }
    
    :global(.pinned-author) {
        font-weight: bold;
        font-size: 0.8rem;
        color: var(--color-primary);
        margin-bottom: 2px;
    }
    
    :global(.pinned-text) {
        color: var(--color-text-main);
        font-size: 0.85rem;
    }

    :global(.pin-btn) {
        background: rgba(59, 130, 246, 0.2);
        border: 1px solid rgba(59, 130, 246, 0.5);
        color: #3b82f6;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        padding: 4px;
        transition: all 0.2s ease;
        opacity: 1;
    }
    
    :global(.pin-btn:hover) {
        background: #3b82f6;
        color: white;
        border-color: #3b82f6;
        transform: scale(1.1);
    }
    
    :global(.pin-btn svg) {
        width: 100%;
        height: 100%;
        display: block;
    }

    /* Message Styles (injected via JS) */
    :global(.chat-msg) {
        display: flex;
        gap: 10px;
        animation: fadeIn 0.3s ease;
    }
    
    :global(.chat-avatar) {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #333;
    }

    :global(.msg-content) {
        flex: 1;
    }

    :global(.msg-header) {
        display: flex;
        align-items: baseline;
        gap: 8px;
        margin-bottom: 2px;
    }

    :global(.msg-author) {
        font-size: 0.85rem;
        font-weight: bold;
        color: var(--color-text-muted);
    }
    
    :global(.msg-author.verified) {
        color: var(--color-primary);
    }

    :global(.msg-text) {
        font-size: 0.9rem;
        line-height: 1.4;
        word-break: break-word;
    }

    @keyframes pulse-red {
        0% { opacity: 1; }
        50% { opacity: 0.5; }
        100% { opacity: 1; }
    }
    
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
<!-- Define global keyframes just in case -->
<style is:global>
    @keyframes floatUp {
        0% { transform: translateY(0) scale(1); opacity: 1; }
        100% { transform: translateY(-200px) scale(1.5); opacity: 0; }
    }
    .floating-emoji {
        position: absolute;
        font-size: 24px;
        animation: floatUp 2s ease-out forwards;
        bottom: 0;
        pointer-events: none;
    }
</style>

<script>
    interface ChatUser {
        name: string;
        avatar: string;
        isVerified: boolean;
        userId?: string;
    }

    interface ChatMessage {
        _id: string;
        user: ChatUser;
        content: string;
        createdAt: string;
        isPinned?: boolean;
    }

    class LiveChat {
        el: HTMLElement;
        slug: string;
        currentUser: any;
        msgArea: HTMLElement;
        input: HTMLInputElement;
        guestInput: HTMLInputElement | null;
        sendBtn: HTMLElement;
        lastPollTime: number = 0;
        polling: number | undefined;
        reactionsContainer: HTMLElement | null;
        pinnedContainer: HTMLElement | null = null;
        toastEl: HTMLElement | null;
        confirmEl: HTMLElement | null;
        confirmCallback: (() => void) | null = null;
    
        // POLLING CONFIG
        baseInterval = 20000;  // 20s
        idleInterval = 60000;  // 60s
        idleThreshold = 120000; // 2 minutes
        currentInterval = 20000;
        lastInteractionTime = Date.now();
        isTabVisible = true;
    
        constructor(el: HTMLElement) {
            this.el = el;
            this.slug = el.dataset.slug || '';
            const encoded = el.dataset.currentUser || '';
            try {
                this.currentUser = encoded ? JSON.parse(decodeURIComponent(escape(atob(encoded)))) : null;
            } catch(e) {
                this.currentUser = null;
            }
            
            this.msgArea = el.querySelector('#chat-messages') as HTMLElement;
            this.input = el.querySelector('#chat-input') as HTMLInputElement;
            this.guestInput = el.querySelector('#guest-name-input') as HTMLInputElement | null;
            this.sendBtn = el.querySelector('#send-btn') as HTMLElement;
            this.reactionsContainer = el.querySelector('#reactions-container');
            this.pinnedContainer = el.querySelector('#pinned-message-container') as HTMLElement;
            this.toastEl = el.querySelector('#live-chat-toast');
            this.confirmEl = el.querySelector('#live-chat-confirm');
            
            this.init();
        }

        init() {
            this.fetchMessages(); // Initial load
            this.startPolling();
            
            this.sendBtn.addEventListener('click', () => {
                this.recordInteraction();
                this.sendMessage();
            });
            this.input.addEventListener('keypress', (e) => {
                this.recordInteraction();
                if(e.key === 'Enter') this.sendMessage();
            });
            
            // Interaction tracking
            const track = () => this.recordInteraction();
            this.el.addEventListener('mousemove', track);
            this.el.addEventListener('click', track);
            this.el.addEventListener('touchstart', track);

            // Visibility detection
            document.addEventListener('visibilitychange', () => {
                this.isTabVisible = document.visibilityState === 'visible';
                if (this.isTabVisible) {
                    this.resetInterval();
                    this.fetchMessages(); // Immediate refresh
                } else {
                    this.stopPolling();
                }
            });
            
            // Reaction Buttons
            const reactionBtns = this.el.querySelectorAll('.reaction-btn');
            reactionBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                   this.recordInteraction();
                   const type = (btn as HTMLElement).dataset.type;
                   if(type) this.sendReaction(type); 
                });
            });
            
            // Modal Events
            this.el.querySelector('#confirm-cancel')?.addEventListener('click', () => {
                if(this.confirmEl) this.confirmEl.classList.add('hidden');
            });
            
            this.el.querySelector('#confirm-ok')?.addEventListener('click', () => {
                if(this.confirmCallback) this.confirmCallback();
                if(this.confirmEl) this.confirmEl.classList.add('hidden');
            });
        }

        recordInteraction() {
            this.lastInteractionTime = Date.now();
            if (this.currentInterval !== this.baseInterval && this.isTabVisible) {
                this.resetInterval();
            }
        }

        resetInterval() {
            this.currentInterval = this.baseInterval;
            this.startPolling();
        }

        startPolling() {
            this.stopPolling();
            if (!this.isTabVisible) return;
            this.polling = window.setInterval(() => {
                const idleTime = Date.now() - this.lastInteractionTime;
                if (idleTime > this.idleThreshold) {
                    if (this.currentInterval !== this.idleInterval) {
                        this.currentInterval = this.idleInterval;
                        this.startPolling();
                    }
                }
                this.fetchMessages();
            }, this.currentInterval);
        }

        stopPolling() {
            if (this.polling) clearInterval(this.polling);
            this.polling = undefined;
        }

        animateMessageDelete(id: string) {
            const el = this.msgArea.querySelector(`.chat-msg[data-id="${id}"]`) as HTMLElement;
            if (el && el.style.opacity !== '0') {
                el.style.opacity = '0';
                el.style.transform = 'translateX(20px)';
                setTimeout(() => el.remove(), 300);
            }
        }
        
        showToast(msg: string, type: 'success' | 'error' = 'success') {
            if(!this.toastEl) return;
            this.toastEl.textContent = msg;
            this.toastEl.className = `toast visible ${type}`;
            this.toastEl.style.display = 'block';
            
            setTimeout(() => {
                if(this.toastEl) {
                   this.toastEl.classList.remove('visible');
                   setTimeout(() => { if(this.toastEl) this.toastEl.style.display = 'none'; }, 300);
                }
            }, 3000);
        }
        
        showConfirm(msg: string, onConfirm: () => void) {
            if(!this.confirmEl) return;
            const txt = this.confirmEl.querySelector('#confirm-text');
            if(txt) txt.textContent = msg;
            this.confirmCallback = onConfirm;
            this.confirmEl.classList.remove('hidden');
        }
        
        async sendReaction(type: string) {
            this.spawnFloatingEmoji(type);
            try {
                fetch(`/api/live-chat/${this.slug}/reaction`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ type })
                });
            } catch(e) {
                console.error("Reaction error", e);
            }
        }
        
        spawnFloatingEmoji(type: string) {
            if(!this.reactionsContainer) return;
            
            const emojiMap: Record<string, string> = {
                'heart': '❤️',
                'fire': '🔥',
                'clap': '👏',
                '100': '💯' 
            };
            
            const el = document.createElement('div');
            el.className = 'floating-emoji';
            el.textContent = emojiMap[type] || '❤️';
            el.style.left = `${Math.random() * 100}vw`;
            el.style.bottom = '-50px';
            el.style.animationDuration = `${2 + Math.random() * 2}s`;
            
            this.reactionsContainer.appendChild(el);
            setTimeout(() => el.remove(), 4000);
        }

        async fetchMessages() {
            if (!this.isTabVisible) return;
            try {
                let url = `/api/live-chat/${this.slug}`;
                if (this.lastPollTime > 0) {
                    url += `?since=${this.lastPollTime}`;
                }
                
                const res = await fetch(url);
                const data = await res.json();
                
                if(data.success) {
                    if (data.timestamp) this.lastPollTime = data.timestamp;

                    this.renderPinnedMessage(data.pinnedMessage || null);
                    
                    if (data.messages && Array.isArray(data.messages)) {
                         this.renderMessages(data.messages);
                    }
                    
                    if (data.deletedIds && Array.isArray(data.deletedIds)) {
                        data.deletedIds.forEach((id: string) => this.animateMessageDelete(id));
                    }

                    if (data.reactions && Object.keys(data.reactions).length > 0) {
                        Object.keys(data.reactions).forEach(type => {
                            const count = Math.min(data.reactions[type], 10);
                            for(let i=0; i<count; i++) {
                                setTimeout(() => this.spawnFloatingEmoji(type), Math.random() * 3000);
                            }
                        });
                    }
                }
            } catch(e) {
                console.error("Chat fetch error", e);
            }
        }

        async sendMessage() {
            const text = this.input.value.trim();
            if(!text) return;
            
            let guestName = null;
            if(!this.currentUser) {
                if(this.guestInput) {
                    guestName = this.guestInput.value.trim();
                    if(!guestName) {
                        this.showToast("Por favor, introduce tu nombre.", "error");
                        this.guestInput.focus();
                        return;
                    }
                }
            }

            const originalValue = this.input.value;
            this.input.value = '';
            
            try {
                const res = await fetch(`/api/live-chat/${this.slug}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        message: text,
                        guestName
                    })
                });
                
                const data = await res.json();

                if(data.success && data.message) {
                    this.renderMessages([data.message]);
                } else {
                    this.input.value = originalValue;
                    this.showToast(data.error || "Error enviando mensaje", "error");
                }
            } catch(e) {
                this.input.value = originalValue;
                this.showToast("Error de conexión.", "error");
            }
        }

        renderMessages(messages: ChatMessage[]) {
            messages.forEach(msg => {
                const exists = this.msgArea.querySelector(`[data-id="${msg._id}"]`);
                if(!exists) {
                    const msgEl = this.createMessageElement(msg);
                    this.msgArea.appendChild(msgEl);
                    this.msgArea.scrollTop = this.msgArea.scrollHeight;
                }
            });
        }

        renderPinnedMessage(msg: ChatMessage | null) {
            if (!this.pinnedContainer) return;
            
            if (!msg) {
                this.pinnedContainer.style.display = 'none';
                this.pinnedContainer.innerHTML = '';
                return;
            }
            
            this.pinnedContainer.style.display = 'flex';
            this.pinnedContainer.className = 'pinned-message';
            this.pinnedContainer.innerHTML = `
                <div class="pinned-icon">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
                        <path d="M16 2a2 2 0 0 1 2 2v6h2a1 1 0 0 1 1 1v2H3v-2a1 1 0 0 1 1-1h2V4a2 2 0 0 1 2-2h8zM6 14v-2h12v2H6zm0 2h12v2a1 1 0 0 1-1 1h-4v4h-2v-4H7a1 1 0 0 1-1-1v-2z"/>
                    </svg>
                </div>
                <div class="pinned-content">
                    <div class="pinned-author">${this.escapeHtml(msg.user.name)}</div>
                    <div class="pinned-text">${this.escapeHtml(msg.content)}</div>
                </div>
                ${this.currentUser && (this.currentUser.role === 'admin' || this.currentUser.role === 'owner') ? `
                <button class="delete-btn" title="Desfijar">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
                ` : ''}
            `;
            
            const unpinBtn = this.pinnedContainer.querySelector('.delete-btn');
            if(unpinBtn) {
                unpinBtn.addEventListener('click', () => {
                   this.togglePin(msg._id, false);
                });
            }
        }

        createMessageElement(msg: ChatMessage) {
            const div = document.createElement('div');
            div.className = 'chat-msg';
            div.dataset.id = msg._id;
            
            const isAdmin = this.currentUser && (this.currentUser.role === 'admin' || this.currentUser.role === 'owner');
            
            div.innerHTML = `
                <img src="${this.escapeHtml(msg.user.avatar)}" alt="${this.escapeHtml(msg.user.name)}" class="chat-avatar">
                <div class="msg-content">
                    <div class="msg-header">
                        <span class="msg-author ${msg.user.isVerified ? 'verified' : ''}">
                            ${this.escapeHtml(msg.user.name)}
                            ${msg.user.isVerified ? '✓' : ''}
                        </span>
                        ${isAdmin ? `
                        <div class="admin-actions">
                            <button class="pin-btn" title="Fijar mensaje">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                                </svg>
                            </button>
                            <button class="ban-btn" title="Bloquear usuario">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line>
                                </svg>
                            </button>
                            <button class="delete-btn" title="Borrar mensaje">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="3 6 5 6 21 6"></polyline>
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                    <line x1="10" y1="11" x2="10" y2="17"></line>
                                    <line x1="14" y1="11" x2="14" y2="17"></line>
                                </svg>
                            </button>
                        </div>` : ''}
                    </div>
                    <div class="msg-text">${this.escapeHtml(msg.content)}</div>
                </div>
            `;
            
            if(isAdmin) {
                div.querySelector('.delete-btn')?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    this.deleteMessage(msg._id, div);
                });
                
                div.querySelector('.ban-btn')?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    this.banUser(msg._id, msg.user.name);
                });
                
                div.querySelector('.pin-btn')?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    this.togglePin(msg._id, true);
                });
            }
            
            return div;
        }
        
        async banUser(messageId: string, userName: string) {
            this.showConfirm(`¿Bloquear permanentemente a ${userName}?`, async () => {
                try {
                    const res = await fetch(`/api/live-chat/${this.slug}/ban`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ messageId })
                    });
                    const data = await res.json();
                    
                    if(data.success) {
                        this.showToast(`Usuario ${userName} bloqueado.`, "success");
                    } else {
                        this.showToast('Error al bloquear: ' + data.error, "error");
                    }
                } catch(e) {
                    console.error(e);
                    this.showToast('Error de conexión', "error");
                }
            });
        }
        
        async togglePin(messageId: string, isPinned: boolean) {
            try {
                const res = await fetch(`/api/live-chat/message/${messageId}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ isPinned })
                });
                const data = await res.json();
                
                if(data.success) {
                    // BROADCAST to peers
                    this.broadcast({ type: 'pin', pinnedMessage: isPinned ? data.message : null });
                    this.renderPinnedMessage(isPinned ? data.message : null);
                    this.showToast(isPinned ? "Mensaje fijado" : "Mensaje desfijado", "success");
                } else {
                    this.showToast(data.error || "Error al fijar", "error");
                }
            } catch(e) {
                console.error(e);
                this.showToast("Connection error", "error");
            }
        }

        async deleteMessage(id: string, el: HTMLElement) {
            el.style.opacity = '0.3';
            el.style.pointerEvents = 'none';
            
            try {
                const res = await fetch(`/api/live-chat/message/${id}`, { method: 'DELETE' });
                const data = await res.json();
                
                if(data.success) {
                    this.broadcast({ type: 'delete', messageId: id });
                    this.animateMessageDelete(id);
                    this.showToast("Mensaje eliminado", "success");
                } else {
                    el.style.opacity = '1';
                    el.style.pointerEvents = 'auto';
                    this.showToast(data.error || "Error al borrar", "error");
                }
            } catch(e) {
                console.error(e);
                el.style.opacity = '1';
                el.style.pointerEvents = 'auto';
                this.showToast("Error de conexión", "error");
            }
        }

        escapeHtml(text: string): string {
             const div = document.createElement('div');
             div.textContent = text;
             return div.innerHTML;
        }

        destroy() {
             if (this.peer) this.peer.destroy();
        }
    }

    // Clean up old instances to prevent dual polling on navigation
    let activeChat: LiveChat | null = null;

    // Initialize logic
    const initChat = () => {
        // Cleanup existing
        if(activeChat) {
            activeChat.destroy();
            activeChat = null;
        }
        
        const el = document.getElementById('live-chat-widget');
        if(el) {
            console.log("Initializing LiveChat widget...");
            activeChat = new LiveChat(el);
        } else {
            console.warn("LiveChat widget element not found");
        }
    };

    // Support both standard page loads and View Transitions
    document.addEventListener('DOMContentLoaded', initChat);
    document.addEventListener('astro:page-load', initChat);
</script>
