---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/dashboard/admin', label: '📊 Dashboard', active: currentPath === '/dashboard/admin' },
  { href: '/dashboard/admin/users', label: '👥 Usuarios', active: currentPath === '/dashboard/admin/users' },
  { href: '/dashboard/admin/user-stats', label: '📈 Analíticas', active: currentPath === '/dashboard/admin/user-stats' },
  { href: '/dashboard/admin/content', label: '🎙️ Contenido', active: currentPath === '/dashboard/admin/content' },
  { href: '/dashboard/admin/live', label: '🔴 En Vivo', active: currentPath === '/dashboard/admin/live' },
  { href: '/dashboard/admin/interviews', label: '📅 Entrevistas', active: currentPath.startsWith('/dashboard/admin/interviews') },
  { href: '/dashboard/admin/push', label: '🔔 Push', active: currentPath.startsWith('/dashboard/admin/push') },
  { href: '/studio/remote', label: '🎙️ Studio Remoto', active: currentPath.startsWith('/studio/remote') },
];
---

<nav class="mb-8 border-b border-white/5">
  <div class="flex gap-2 overflow-x-auto pb-px">
    {navLinks.map(({ href, label, active }) => (
      <a 
        href={href} 
        class:list={[
          "px-5 py-3 text-[0.95rem] font-medium whitespace-nowrap transition-all duration-200 border-b-2 hover:text-white hover:bg-white/5 hover:rounded-t-lg",
          {
            "text-violet-400 border-violet-400": active,
            "text-zinc-400 border-transparent": !active
          }
        ]}
      >
        {label}
      </a>
    ))}
  </div>
</nav>

<script define:vars={{ currentPath: Astro.url.pathname }}>
  // Optional: Client-side active state if not strictly SSR
</script>

