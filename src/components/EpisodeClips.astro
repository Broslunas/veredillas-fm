---
interface Clip {
  title: string;
  url: string;
}

interface Props {
  clips?: Clip[];
}

const { clips } = Astro.props;

function toEmbedUrl(url: string): string {
  const patterns = [
    /youtube\.com\/shorts\/([^?&]+)/,
    /(?:youtube\.com\/watch\?v=|youtube\.com\/watch\?.+&v=)([^&]+)/,
    /youtu\.be\/([^?&]+)/,
    /youtube\.com\/embed\/([^?&]+)/,
  ];
  for (const pattern of patterns) {
    const match = url.match(pattern);
    if (match) return `https://www.youtube.com/embed/${match[1]}`;
  }
  return url;
}

const embedClips = clips?.map(clip => ({
  title: clip.title,
  embedUrl: toEmbedUrl(clip.url),
})) ?? [];
---

{embedClips.length > 0 && (
  <>
    <button class="clips-premium-trigger" id="clips-open-btn">
      <div class="trigger-glow"></div>
      <div class="trigger-content">
        <div class="play-icon-container">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="play-icon"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
        </div>
        <div class="trigger-info">
          <span class="trigger-label">Clips Destacados</span>
          <div class="trigger-subinfo">
            <span class="pulse-dot"></span>
            <span class="count-tag">{embedClips.length} momentos clave</span>
          </div>
        </div>
        <svg class="arrow-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </div>
    </button>

    <!-- Cinematic Clips Modal -->
    <div class="clips-cinematic-modal" id="clips-modal-overlay">
      <div class="modal-backdrop"></div>
      <div class="modal-noise"></div>
      
      <div class="modal-interface">
        <header class="modal-header">
          <div class="header-branding">
            <div class="branding-ring">
              <span class="vfm-logo">VFM</span>
            </div>
            <div class="header-titles">
              <span class="eyebrow">Clips & Momentos</span>
              <h3 class="modal-main-title">Destacados del episodio</h3>
            </div>
          </div>
          
          <button class="modal-close-action" id="clips-close-btn" aria-label="Cerrar cinemática">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </header>

        <main class="carousel-theatre">
          <div class="carousel-viewport">
            <div class="carousel-track" id="clips-carousel">
              {embedClips.map((clip, i) => (
                <div class="carousel-slide" data-index={i}>
                  <div class="video-scaffold">
                    <div class="video-container">
                      <iframe
                        data-src={clip.embedUrl}
                        title={clip.title}
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        allowfullscreen
                      ></iframe>
                    </div>
                    <div class="video-reflection"></div>
                  </div>
                  
                  <div class="slide-info">
                    <div class="info-header">
                      <span class="slide-index">Momento {String(i + 1).padStart(2, '0')}</span>
                    </div>
                    <h4 class="slide-title">{clip.title}</h4>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <nav class="theatre-controls">
            {embedClips.length > 1 && (
              <button class="nav-arrow prev" id="clips-prev" aria-label="Anterior">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
              </button>
              <button class="nav-arrow next" id="clips-next" aria-label="Siguiente">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </button>
            )}
          </nav>
        </main>

        <footer class="modal-footer">
          <div class="progress-indicator" id="clips-dots">
            {embedClips.map((_, i) => (
              <button class:list={["progress-segment", { active: i === 0 }]} data-dot-index={i} aria-label={`Ir al clip ${i + 1}`}>
                <span class="segment-fill"></span>
              </button>
            ))}
          </div>
        </footer>
      </div>
    </div>
  </>
)}

<script>
  function initClips() {
    const openBtn = document.getElementById('clips-open-btn');
    const overlay = document.getElementById('clips-modal-overlay');
    const closeBtn = document.getElementById('clips-close-btn');
    const track = document.getElementById('clips-carousel');
    const prevBtn = document.getElementById('clips-prev');
    const nextBtn = document.getElementById('clips-next');
    const dotsContainer = document.getElementById('clips-dots');

    if (!openBtn || !overlay || !closeBtn || !track) return;

    const slides = Array.from(track.querySelectorAll('.carousel-slide'));
    const segments = dotsContainer ? Array.from(dotsContainer.querySelectorAll('.progress-segment')) : [];
    let currentIndex = 0;

    function loadIframe(index: number) {
      const slide = slides[index];
      if (!slide) return;
      const iframe = slide.querySelector('iframe');
      if (iframe && !iframe.hasAttribute('src') && iframe.dataset.src) {
        iframe.src = iframe.dataset.src;
      }
    }

    function updateView(index: number) {
      if (index < 0 || index >= slides.length) return;
      currentIndex = index;

      // Smooth slide transition
      track.style.transform = `translateX(${-index * 100}%)`;

      // Update progress segments
      segments.forEach((seg, i) => {
        seg.classList.toggle('active', i === index);
      });

      // Lazy load logic
      loadIframe(index);
      if (index > 0) loadIframe(index - 1);
      if (index < slides.length - 1) loadIframe(index + 1);
    }

    function unloadAll() {
      slides.forEach(slide => {
        const iframe = slide.querySelector('iframe');
        if (iframe) iframe.removeAttribute('src');
      });
    }

    openBtn.addEventListener('click', () => {
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
      updateView(0);
    });

    closeBtn.addEventListener('click', () => {
      overlay.classList.remove('active');
      document.body.style.overflow = '';
      setTimeout(unloadAll, 400); // Wait for transition
    });

    if (prevBtn) prevBtn.addEventListener('click', () => updateView(currentIndex - 1));
    if (nextBtn) nextBtn.addEventListener('click', () => updateView(currentIndex + 1));

    segments.forEach(seg => {
      seg.addEventListener('click', () => {
        const idx = parseInt((seg as HTMLElement).dataset.dotIndex || '0');
        updateView(idx);
      });
    });

    // Keys
    document.addEventListener('keydown', (e) => {
      if (!overlay.classList.contains('active')) return;
      if (e.key === 'Escape') closeBtn.click();
      if (e.key === 'ArrowLeft') updateView(currentIndex - 1);
      if (e.key === 'ArrowRight') updateView(currentIndex + 1);
    });
  }

  document.addEventListener('DOMContentLoaded', initClips);
  document.addEventListener('astro:page-load', initClips);
</script>

<style>
  /* ── Premium Trigger Button ── */
  .clips-premium-trigger {
    position: relative;
    width: 100%;
    padding: 1rem;
    background: rgba(139, 92, 246, 0.05);
    border: 1px solid rgba(139, 92, 246, 0.2);
    border-radius: 20px;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    margin-bottom: 2rem;
  }

  .trigger-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(139, 92, 246, 0.15), transparent 70%);
    opacity: 0;
    transition: opacity 0.4s;
  }

  .clips-premium-trigger:hover {
    background: rgba(139, 92, 246, 0.1);
    border-color: rgba(139, 92, 246, 0.4);
    transform: translateY(-2px);
    box-shadow: 0 15px 30px -10px rgba(139, 92, 246, 0.2);
  }

  .clips-premium-trigger:hover .trigger-glow {
    opacity: 1;
  }

  .trigger-content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .play-icon-container {
    width: 44px;
    height: 44px;
    background: var(--color-primary);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    box-shadow: 0 4px 15px rgba(139, 92, 246, 0.4);
    transition: all 0.3s ease;
  }

  .clips-premium-trigger:hover .play-icon-container {
    transform: scale(1.1) rotate(5deg);
    box-shadow: 0 6px 20px rgba(139, 92, 246, 0.5);
  }

  .trigger-info {
    flex: 1;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .trigger-label {
    font-size: 1rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.01em;
  }

  .trigger-subinfo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .pulse-dot {
    width: 6px;
    height: 6px;
    background: #ef4444;
    border-radius: 50%;
    animation: p-pulse 2s infinite;
  }

  @keyframes p-pulse {
    0% { transform: scale(1); opacity: 1; box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
    70% { transform: scale(1.2); opacity: 0.5; box-shadow: 0 0 0 6px rgba(239, 68, 68, 0); }
    100% { transform: scale(1); opacity: 1; box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
  }

  .count-tag {
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.5);
  }

  .arrow-icon {
    color: rgba(255, 255, 255, 0.3);
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .clips-premium-trigger:hover .arrow-icon {
    transform: translateX(4px);
    color: var(--color-primary);
  }

  /* ── Cinematic Modal Overlay ── */
  .clips-cinematic-modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    flex-direction: column;
    opacity: 0;
    visibility: hidden;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .clips-cinematic-modal.active {
    opacity: 1;
    visibility: visible;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: #050508;
    background-image: 
      radial-gradient(circle at 10% 10%, rgba(139, 92, 246, 0.1) 0%, transparent 40%),
      radial-gradient(circle at 90% 90%, rgba(239, 68, 68, 0.05) 0%, transparent 40%);
    z-index: 0;
  }

  .modal-noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.03;
    z-index: 1;
    pointer-events: none;
  }

  .modal-interface {
    position: relative;
    z-index: 10;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: env(safe-area-inset-top) 0 env(safe-area-inset-bottom);
  }

  /* Header Branding */
  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
  }

  .header-branding {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .branding-ring {
    width: 48px;
    height: 48px;
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vfm-logo {
    font-size: 0.75rem;
    font-weight: 900;
    color: var(--color-primary);
    letter-spacing: 0.1em;
  }

  .header-titles {
    display: flex;
    flex-direction: column;
  }

  .eyebrow {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--color-primary);
    letter-spacing: 0.15em;
  }

  .modal-main-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
    color: white;
  }

  .modal-close-action {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s;
  }

  .modal-close-action:hover {
    background: rgba(239, 68, 68, 0.1);
    border-color: rgba(239, 68, 68, 0.3);
    color: #ef4444;
    transform: rotate(90deg);
  }

  /* Carousel */
  .carousel-theatre {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 0;
  }

  .carousel-viewport {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .carousel-slide {
    flex: 0 0 100%;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    min-height: 0;
  }

  .video-scaffold {
    position: relative;
    height: min(70vh, 600px);
    aspect-ratio: 9/16;
    perspective: 1000px;
  }

  .video-container {
    width: 100%;
    height: 100%;
    background: black;
    border-radius: 24px;
    overflow: hidden;
    position: relative;
    z-index: 10;
    box-shadow: 
      0 0 0 1px rgba(255, 255, 255, 0.1),
      0 30px 60px -15px rgba(0, 0, 0, 0.8);
  }

  .video-container iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-reflection {
    position: absolute;
    bottom: -15%;
    left: 10%;
    right: 10%;
    height: 30%;
    background: linear-gradient(to bottom, rgba(139, 92, 246, 0.15), transparent);
    filter: blur(40px);
    z-index: 1;
    opacity: 0.5;
    pointer-events: none;
  }

  .slide-info {
    text-align: center;
    max-width: 500px;
  }

  .slide-index {
    font-size: 0.8rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .slide-title {
    margin: 0.5rem 0 0;
    font-size: 1.5rem;
    font-weight: 800;
    color: white;
    line-height: 1.2;
    background: linear-gradient(to right, #fff, rgba(255, 255, 255, 0.7));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Nav Controls */
  .theatre-controls {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 50;
  }

  .nav-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 64px;
    height: 64px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 50%;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    pointer-events: auto;
    backdrop-filter: blur(12px);
    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .nav-arrow:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-50%) scale(1.1);
  }

  .nav-arrow.prev { left: 2rem; }
  .nav-arrow.next { right: 2rem; }

  /* Footer Progress */
  .modal-footer {
    padding: 2rem;
    display: flex;
    justify-content: center;
  }

  .progress-indicator {
    display: flex;
    gap: 12px;
  }

  .progress-segment {
    width: 40px;
    height: 4px;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    padding: 0;
    border-radius: 2px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .segment-fill {
    position: absolute;
    inset: 0;
    background: var(--color-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .progress-segment.active .segment-fill {
    transform: scaleX(1);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .nav-arrow {
      width: 50px;
      height: 50px;
    }
  }

  @media (max-width: 768px) {
    .modal-header { padding: 1rem; }
    .video-scaffold { height: min(60vh, 500px); }
    .slide-title { font-size: 1.25rem; }
    .nav-arrow { display: none; }
  }
</style>
