---
// AchievementsPanel.astro — Achievements grid with confetti, category filter, skeleton loading
---

<!-- ── Stats Summary Banner (updated by JS) ── -->
<div class="mb-6 min-h-0 transition-[min-height] duration-300" id="ach-summary" aria-hidden="true">
  <div class="flex gap-4 flex-wrap" id="ach-summary-inner">
    <!-- filled by JS -->
  </div>
</div>

<!-- ── Category Filter ── -->
<div class="flex gap-2 flex-wrap mb-5" role="tablist" aria-label="Filtrar logros por categoría">
  <button class="filter-pill group active inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-white/10 bg-white/5 text-zinc-400 text-[0.8rem] font-medium cursor-pointer transition-all duration-200 whitespace-nowrap font-sans hover:bg-white/10 hover:border-white/20 hover:text-zinc-200 hover:-translate-y-px [&.active]:bg-gradient-to-br [&.active]:from-violet-600/30 [&.active]:to-pink-500/20 [&.active]:border-violet-500/55 [&.active]:text-violet-100 [&.active]:font-semibold [&.active]:shadow-lg [&.active]:shadow-violet-600/20" data-cat="all" role="tab" aria-selected="true">
    <span class="pill-label">✦ Todos</span>
    <span class="pill-count inline-flex items-center justify-center min-w-[20px] h-[18px] px-1.5 rounded-full bg-white/10 text-[0.68rem] font-bold text-zinc-500 transition-colors group-[.active]:bg-violet-500/30 group-[.active]:text-violet-300" id="pill-count-all">–</span>
  </button>
  <button class="filter-pill group inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-white/10 bg-white/5 text-zinc-400 text-[0.8rem] font-medium cursor-pointer transition-all duration-200 whitespace-nowrap font-sans hover:bg-white/10 hover:border-white/20 hover:text-zinc-200 hover:-translate-y-px [&.active]:bg-gradient-to-br [&.active]:from-violet-600/30 [&.active]:to-pink-500/20 [&.active]:border-violet-500/55 [&.active]:text-violet-100 [&.active]:font-semibold [&.active]:shadow-lg [&.active]:shadow-violet-600/20" data-cat="escucha" role="tab" aria-selected="false">
    <span class="group-hover:scale-110 transition-transform">🎧</span>
    <span class="pill-label">Escucha</span>
    <span class="pill-count inline-flex items-center justify-center min-w-[20px] h-[18px] px-1.5 rounded-full bg-white/10 text-[0.68rem] font-bold text-zinc-500 transition-colors group-[.active]:bg-violet-500/30 group-[.active]:text-violet-300" id="pill-count-escucha">–</span>
  </button>
  <button class="filter-pill group inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-white/10 bg-white/5 text-zinc-400 text-[0.8rem] font-medium cursor-pointer transition-all duration-200 whitespace-nowrap font-sans hover:bg-white/10 hover:border-white/20 hover:text-zinc-200 hover:-translate-y-px [&.active]:bg-gradient-to-br [&.active]:from-violet-600/30 [&.active]:to-pink-500/20 [&.active]:border-violet-500/55 [&.active]:text-violet-100 [&.active]:font-semibold [&.active]:shadow-lg [&.active]:shadow-violet-600/20" data-cat="fidelidad" role="tab" aria-selected="false">
    <span class="group-hover:scale-110 transition-transform">🔥</span>
    <span class="pill-label">Fidelidad</span>
    <span class="pill-count inline-flex items-center justify-center min-w-[20px] h-[18px] px-1.5 rounded-full bg-white/10 text-[0.68rem] font-bold text-zinc-500 transition-colors group-[.active]:bg-violet-500/30 group-[.active]:text-violet-300" id="pill-count-fidelidad">–</span>
  </button>
  <button class="filter-pill group inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-white/10 bg-white/5 text-zinc-400 text-[0.8rem] font-medium cursor-pointer transition-all duration-200 whitespace-nowrap font-sans hover:bg-white/10 hover:border-white/20 hover:text-zinc-200 hover:-translate-y-px [&.active]:bg-gradient-to-br [&.active]:from-violet-600/30 [&.active]:to-pink-500/20 [&.active]:border-violet-500/55 [&.active]:text-violet-100 [&.active]:font-semibold [&.active]:shadow-lg [&.active]:shadow-violet-600/20" data-cat="social" role="tab" aria-selected="false">
    <span class="group-hover:scale-110 transition-transform">💬</span>
    <span class="pill-label">Social</span>
    <span class="pill-count inline-flex items-center justify-center min-w-[20px] h-[18px] px-1.5 rounded-full bg-white/10 text-[0.68rem] font-bold text-zinc-500 transition-colors group-[.active]:bg-violet-500/30 group-[.active]:text-violet-300" id="pill-count-social">–</span>
  </button>
  <button class="filter-pill group inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-white/10 bg-white/5 text-zinc-400 text-[0.8rem] font-medium cursor-pointer transition-all duration-200 whitespace-nowrap font-sans hover:bg-white/10 hover:border-white/20 hover:text-zinc-200 hover:-translate-y-px [&.active]:bg-gradient-to-br [&.active]:from-violet-600/30 [&.active]:to-pink-500/20 [&.active]:border-violet-500/55 [&.active]:text-violet-100 [&.active]:font-semibold [&.active]:shadow-lg [&.active]:shadow-violet-600/20" data-cat="coleccion" role="tab" aria-selected="false">
    <span class="group-hover:scale-110 transition-transform">❤️</span>
    <span class="pill-label">Colección</span>
    <span class="pill-count inline-flex items-center justify-center min-w-[20px] h-[18px] px-1.5 rounded-full bg-white/10 text-[0.68rem] font-bold text-zinc-500 transition-colors group-[.active]:bg-violet-500/30 group-[.active]:text-violet-300" id="pill-count-coleccion">–</span>
  </button>
  <button class="filter-pill group inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-white/10 bg-white/5 text-zinc-400 text-[0.8rem] font-medium cursor-pointer transition-all duration-200 whitespace-nowrap font-sans hover:bg-white/10 hover:border-white/20 hover:text-zinc-200 hover:-translate-y-px [&.active]:bg-gradient-to-br [&.active]:from-violet-600/30 [&.active]:to-pink-500/20 [&.active]:border-violet-500/55 [&.active]:text-violet-100 [&.active]:font-semibold [&.active]:shadow-lg [&.active]:shadow-violet-600/20" data-cat="exploracion" role="tab" aria-selected="false">
    <span class="group-hover:scale-110 transition-transform">🗺️</span>
    <span class="pill-label">Exploración</span>
    <span class="pill-count inline-flex items-center justify-center min-w-[20px] h-[18px] px-1.5 rounded-full bg-white/10 text-[0.68rem] font-bold text-zinc-500 transition-colors group-[.active]:bg-violet-500/30 group-[.active]:text-violet-300" id="pill-count-exploracion">–</span>
  </button>
  <button class="filter-pill group inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-white/10 bg-white/5 text-zinc-400 text-[0.8rem] font-medium cursor-pointer transition-all duration-200 whitespace-nowrap font-sans hover:bg-white/10 hover:border-white/20 hover:text-zinc-200 hover:-translate-y-px [&.active]:bg-gradient-to-br [&.active]:from-violet-600/30 [&.active]:to-pink-500/20 [&.active]:border-violet-500/55 [&.active]:text-violet-100 [&.active]:font-semibold [&.active]:shadow-lg [&.active]:shadow-violet-600/20" data-cat="especial" role="tab" aria-selected="false">
    <span class="group-hover:scale-110 transition-transform">✨</span>
    <span class="pill-label">Especial</span>
    <span class="pill-count inline-flex items-center justify-center min-w-[20px] h-[18px] px-1.5 rounded-full bg-white/10 text-[0.68rem] font-bold text-zinc-500 transition-colors group-[.active]:bg-violet-500/30 group-[.active]:text-violet-300" id="pill-count-especial">–</span>
  </button>
  <button class="filter-pill group inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-white/10 bg-white/5 text-zinc-400 text-[0.8rem] font-medium cursor-pointer transition-all duration-200 whitespace-nowrap font-sans hover:bg-white/10 hover:border-white/20 hover:text-zinc-200 hover:-translate-y-px [&.active]:bg-gradient-to-br [&.active]:from-violet-600/30 [&.active]:to-pink-500/20 [&.active]:border-violet-500/55 [&.active]:text-violet-100 [&.active]:font-semibold [&.active]:shadow-lg [&.active]:shadow-violet-600/20" data-cat="madrugador" role="tab" aria-selected="false">
    <span class="group-hover:scale-110 transition-transform">🌙</span>
    <span class="pill-label">Madrugador</span>
    <span class="pill-count inline-flex items-center justify-center min-w-[20px] h-[18px] px-1.5 rounded-full bg-white/10 text-[0.68rem] font-bold text-zinc-500 transition-colors group-[.active]:bg-violet-500/30 group-[.active]:text-violet-300" id="pill-count-madrugador">–</span>
  </button>
</div>

<!-- ── Sort + Search bar ── -->
<div class="flex items-center gap-3 mb-6 flex-wrap">
  <div class="relative flex-1 min-w-[180px]">
    <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-zinc-500 pointer-events-none" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input class="w-full pl-10 pr-4 py-2.5 rounded-full border border-white/10 bg-white/5 text-white text-[0.85rem] transition-all focus:outline-none focus:border-violet-500/50 focus:bg-white/10 focus:ring-4 focus:ring-violet-500/12 placeholder:text-zinc-600" id="ach-search" type="search" placeholder="Buscar logro..." autocomplete="off" />
  </div>
  <div class="flex items-center gap-2">
    <label class="text-[0.8rem] text-zinc-500 whitespace-nowrap" for="ach-sort">Ordenar:</label>
    <select class="pl-3.5 pr-8 py-2.5 rounded-full border border-white/10 bg-white/5 text-white text-[0.82rem] cursor-pointer appearance-none bg-[url('data:image/svg+xml,%3Csvg_width=%2210%22_height=%226%22_viewBox=%220_0_10_6%22_fill=%22none%22_xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cpath_d=%22M1_1L5_5L9_1%22_stroke=%22rgba(255,255,255,0.4)%22_stroke-width=%221.5%22_stroke-linecap=%22round%22/%3E%3C/svg%3E')] bg-no-repeat bg-[position:right_0.8rem_center] transition-all focus:outline-none focus:border-violet-500/50 focus:ring-4 focus:ring-violet-500/12" id="ach-sort">
      <option value="default">Por rareza</option>
      <option value="newest">Más reciente</option>
      <option value="points">Por puntos</option>
      <option value="az">A → Z</option>
    </select>
  </div>
  <div class="flex border border-white/10 rounded-xl overflow-hidden shrink-0">
    <button class="view-btn flex items-center justify-center p-2.5 bg-white/5 text-zinc-400 transition-colors hover:bg-white/10 hover:text-white active [&.active]:bg-violet-600/30 [&.active]:text-violet-300" id="view-grid" title="Vista cuadrícula" aria-label="Vista cuadrícula">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
    </button>
    <button class="view-btn flex items-center justify-center p-2.5 bg-white/5 text-zinc-400 transition-colors hover:bg-white/10 hover:text-white border-l border-white/10 [&.active]:bg-violet-600/30 [&.active]:text-violet-300" id="view-list" title="Vista lista" aria-label="Vista lista">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
    </button>
  </div>
</div>

<!-- ── Grid ── -->
<div class="ach-grid grid grid-cols-[repeat(auto-fill,minmax(270px,1fr))] gap-4 [&.list-view]:grid-cols-1" id="ach-grid" role="list">
  <!-- Skeleton while loading -->
  {Array.from({ length: 15 }).map((_, i) => (
    <div class="relative flex items-center gap-4 p-5 rounded-[18px] border border-white/10 bg-zinc-900/40 animate-[skFade_1.6s_infinite] pointer-events-none shadow-sm" style={`animation-delay: ${i * 0.05}s`} aria-hidden="true">
      <div class="w-[54px] h-[54px] bg-white/10 rounded-2xl shrink-0"></div>
      <div class="flex-1 space-y-2">
        <div class="h-2.5 w-1/2 bg-white/10 rounded-full"></div>
        <div class="h-2 w-11/12 bg-white/10 rounded-full"></div>
        <div class="h-2 w-2/3 bg-white/10 rounded-full"></div>
      </div>
    </div>
  ))}
</div>

<!-- ── Empty State ── -->
<div class="hidden flex-col items-center justify-center py-20 px-8 text-center" id="ach-empty">
  <div class="text-5xl opacity-50 mb-4 animate-[emptyBob_3s_infinite]">🔍</div>
  <h3 class="text-xl font-bold bg-gradient-to-r from-white to-zinc-400 bg-clip-text text-transparent mb-2">Sin resultados</h3>
  <p class="text-zinc-500 text-sm">No hay logros que coincidan con tu búsqueda.</p>
</div>

<style is:global>
  /* Core Animations */
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(12px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes skFade {
    0%, 100% { opacity: 0.35; }
    50% { opacity: 0.65; }
  }

  @keyframes emptyBob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  @keyframes progressGlow {
    0%, 100% { filter: brightness(1); }
    50%       { filter: brightness(1.25); }
  }

  @keyframes newPop {
    from { transform: scale(0.6) rotate(-5deg); opacity: 0; }
    to   { transform: scale(1) rotate(0deg);    opacity: 1; }
  }

  @keyframes legendaryShine {
    from { background-position: 200% 0; }
    to   { background-position: -50% 0; }
  }

  @keyframes pulsePill {
    0%, 100% { box-shadow: 0 0 0 0 rgba(124,58,237,0.6); }
    50%       { box-shadow: 0 0 0 7px rgba(124,58,237,0); }
  }

  .badge-card {
    animation: cardIn 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .badge-card.unlocked::after {
    content: '';
    @apply absolute top-0 left-0 right-0 h-[2px] rounded-t-full opacity-50;
    background: linear-gradient(90deg, transparent, var(--badge-color), transparent);
  }

  .list-view .badge-card.unlocked::before {
    content: '';
    @apply absolute inset-y-0 left-0 w-[4px] bg-[var(--badge-color)] rounded-l-[18px] opacity-80;
  }

  .rarity-legendary .badge-shimmer {
    @apply absolute inset-0 pointer-events-none rounded-[inherit];
    background: linear-gradient(115deg, transparent 30%, rgba(245,158,11,0.12) 50%, transparent 70%);
    background-size: 250% 100%;
    animation: legendaryShine 4s linear infinite;
  }

  .badge-icon-glow {
    @apply absolute inset-0 opacity-0 transition-opacity duration-300 rounded-[inherit];
    background: radial-gradient(circle at 50% 50%, var(--badge-color), transparent 70%);
  }

  .badge-card.unlocked:hover .badge-icon-glow {
    @apply opacity-20;
  }

  .badge-progress-fill {
    animation: progressGlow 2.5s ease-in-out infinite;
  }

  .badge-new-pill {
    animation: pulsePill 1.8s ease-in-out infinite;
  }

  .badge-card.is-new {
    animation: newPop 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
</style>

<script>
// @ts-nocheck
interface BadgeData {
  id: string; name: string; description: string; icon: string;
  rarity: string; rarityLabel: string; rarityColor: string;
  category: string; categoryLabel: string;
  points: number; unlocked: boolean; isNew: boolean;
  unlockedAt: string | null; secret: boolean;
  progressCurrent: number | null;
  progressMax: number | null;
  progressPct: number | null;
  progressUnit: string | null;
}

let allBadges: BadgeData[]   = [];
let currentCat  = 'all';
let currentSort = 'default';
let searchQuery = '';
let viewMode: 'grid' | 'list' = 'grid';

const rarityW: Record<string,number> = { legendary:0, epic:1, rare:2, uncommon:3, common:4 };

function fmtDate(iso: string | null) {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('es-ES', { day:'numeric', month:'short', year:'numeric' });
}

function getFiltered(): BadgeData[] {
  let list = currentCat === 'all' ? allBadges : allBadges.filter(b => b.category === currentCat);
  if (searchQuery) {
    const q = searchQuery.toLowerCase();
    list = list.filter(b =>
      b.name.toLowerCase().includes(q) ||
      b.description.toLowerCase().includes(q) ||
      b.rarityLabel.toLowerCase().includes(q) ||
      b.categoryLabel.toLowerCase().includes(q)
    );
  }
  list = [...list].sort((a, b) => {
    if (currentSort === 'az')     return a.name.localeCompare(b.name);
    if (currentSort === 'points') return b.points - a.points;
    if (currentSort === 'newest') {
      if (!a.unlockedAt && !b.unlockedAt) return 0;
      if (!a.unlockedAt) return 1;
      if (!b.unlockedAt) return -1;
      return new Date(b.unlockedAt).getTime() - new Date(a.unlockedAt).getTime();
    }
    if (a.unlocked !== b.unlocked) return a.unlocked ? -1 : 1;
    return (rarityW[a.rarity] ?? 4) - (rarityW[b.rarity] ?? 4);
  });
  return list;
}

function buildCard(b: BadgeData, idx: number): HTMLElement {
  const card = document.createElement('div');
  const isList = viewMode === 'list';
  
  card.className = [
    'badge-card group relative flex flex-col gap-4 p-5 rounded-[18px] border border-white/10 bg-zinc-950/65 backdrop-blur-xl transition-all duration-300 cursor-default overflow-hidden',
    b.unlocked ? 'unlocked hover:-translate-y-1 hover:scale-[1.01] hover:shadow-2xl' : 'locked opacity-40 grayscale-[0.85] brightness-[0.7] hover:opacity-60 hover:grayscale-[0.5] hover:brightness-[0.85]',
    `rarity-${b.rarity}`,
    b.isNew ? 'is-new' : '',
    isList ? '!flex-row !items-center !p-4' : ''
  ].filter(Boolean).join(' ');
  
  card.style.setProperty('--badge-color', b.rarityColor);
  card.style.animationDelay = `${idx * 0.035}s`;
  card.setAttribute('role', 'listitem');
  card.setAttribute('aria-label', `${b.unlocked ? 'Desbloqueado: ' : 'Bloqueado: '}${b.name}`);

  if (b.unlocked) {
    card.style.borderColor = `color-mix(in srgb, ${b.rarityColor} 30%, rgba(255,255,255,0.1))`;
  }

  const secretLock = (!b.unlocked && b.secret);
  const displayName = secretLock ? '???' : b.name;
  const displayDesc = secretLock ? 'Logro secreto — ¡descúbrelo para revelarlo!' : b.description;

  const showProgress = b.progressPct !== null && b.progressPct < 100;
  const progressHTML = showProgress ? `
    <div class="flex flex-col gap-1.5 mt-1">
      <div class="flex justify-between items-center text-[0.68rem]">
        <span class="text-zinc-500 font-medium">${b.progressCurrent} / ${b.progressMax} ${b.progressUnit}</span>
        <span class="font-bold" style="color:${b.rarityColor}">${b.progressPct}%</span>
      </div>
      <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden relative">
        <div class="badge-progress-fill h-full transition-[width] duration-1000 ease-out" style="width:${b.progressPct}%; background: linear-gradient(90deg, ${b.rarityColor}, #fff)"></div>
      </div>
    </div>
  ` : '';

  card.innerHTML = `
    ${b.rarity === 'legendary' ? '<div class="badge-shimmer"></div>' : ''}
    <div class="flex items-start gap-4 ${isList ? 'shrink-0' : ''}">
      <div class="w-[54px] h-[54px] rounded-2xl flex items-center justify-center text-3xl shrink-0 bg-white/5 border border-white/10 relative overflow-hidden transition-all group-hover:scale-110 group-hover:-rotate-3" style="${b.unlocked ? `background:color-mix(in srgb, ${b.rarityColor} 12%, transparent); border-color:color-mix(in srgb, ${b.rarityColor} 28%, transparent)` : ''}">
        <div class="badge-icon-glow"></div>
        <span class="relative z-10">${b.icon}</span>
      </div>
      <div class="flex flex-col gap-1 flex-1 min-w-0">
        <span class="inline-flex items-center gap-1.5 text-[0.65rem] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full border mb-1 w-fit" style="background:color-mix(in srgb, ${b.rarityColor} 18%, transparent); color:${b.rarityColor}; border-color:color-mix(in srgb, ${b.rarityColor} 30%, transparent)">
          <span class="w-1.5 h-1.5 rounded-full" style="background:${b.rarityColor}"></span>
          ${b.rarityLabel}
        </span>
        <p class="text-[0.95rem] font-bold text-zinc-100 leading-tight truncate">${displayName}</p>
      </div>
    </div>
    <div class="flex flex-col flex-1 gap-3">
      <p class="text-[0.8rem] text-zinc-400 leading-relaxed line-clamp-2">${displayDesc}</p>
      ${progressHTML}
      <div class="flex items-center justify-between gap-2 pt-3 border-t border-white/5 mt-auto">
        <div class="flex items-center gap-2">
          ${b.points > 0 ? `<span class="inline-flex items-center gap-1 px-2 py-0.5 text-[0.72rem] font-bold text-amber-400 bg-amber-400/10 border border-amber-400/20 rounded-full">⭐ +${b.points}</span>` : ''}
          ${b.isNew ? '<span class="badge-new-pill text-[0.62rem] font-black uppercase tracking-widest px-2 py-0.5 rounded-full bg-gradient-to-r from-violet-600 to-pink-500 text-white shadow-lg">¡NUEVO!</span>' : ''}
        </div>
        ${b.unlocked && b.unlockedAt
          ? `<span class="text-[0.68rem] text-zinc-500 whitespace-nowrap">🗓 ${fmtDate(b.unlockedAt)}</span>`
          : (!b.unlocked && !showProgress ? `<span class="text-[0.7rem] text-zinc-600 italic">🔒 Por desbloquear</span>` : '')}
      </div>
    </div>
  `;

  return card;
}

function renderGrid() {
  const grid     = document.getElementById('ach-grid')!;
  const emptyEl  = document.getElementById('ach-empty')!;
  const filtered = getFiltered();
  grid.innerHTML = '';
  if (filtered.length === 0) {
    emptyEl.classList.remove('hidden');
    emptyEl.classList.add('flex');
    return;
  }
  emptyEl.classList.add('hidden');
  emptyEl.classList.remove('flex');
  filtered.forEach((b, i) => grid.appendChild(buildCard(b, i)));
}

function updatePillCounts() {
  const cats = ['all','escucha','fidelidad','social','coleccion','exploracion','especial','madrugador'];
  for (const cat of cats) {
    const el = document.getElementById(`pill-count-${cat}`);
    if (!el) continue;
    const count = cat === 'all'
      ? allBadges.filter(b => b.unlocked).length
      : allBadges.filter(b => b.category === cat && b.unlocked).length;
    const total = cat === 'all'
      ? allBadges.length
      : allBadges.filter(b => b.category === cat).length;
    el.textContent = `${count}/${total}`;
  }
}

function updateSummaryBanner(data: { totalUnlocked: number; totalAchievements: number; totalPoints: number }) {
  const inner = document.getElementById('ach-summary-inner');
  if (!inner) return;
  const rarities = [
    { key: 'legendary', label: 'Legendarios',  color: '#f59e0b' },
    { key: 'epic',      label: 'Épicos',        color: '#a855f7' },
    { key: 'rare',      label: 'Raros',         color: '#60a5fa' },
    { key: 'uncommon',  label: 'Poco comunes',  color: '#4ade80' },
    { key: 'common',    label: 'Comunes',       color: '#9ca3af' },
  ];
  inner.innerHTML = rarities.map(r => {
    const cnt = allBadges.filter(b => b.rarity === r.key && b.unlocked).length;
    const total = allBadges.filter(b => b.rarity === r.key).length;
    if (total === 0) return '';
    return `
      <span class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-white/10 text-[0.75rem] font-semibold transition-transform hover:-translate-y-0.5" style="border-color:${r.color}30; color:${r.color}; background: ${r.color}12">
        <span class="w-2 h-2 rounded-full" style="background:${r.color}"></span>
        ${cnt}/${total} ${r.label}
      </span>
    `;
  }).join('');
  const hstatUnlocked = document.getElementById('hstat-unlocked');
  const hstatPoints   = document.getElementById('hstat-points');
  const heroFill      = document.getElementById('hero-progress-fill');
  const heroGlow      = document.getElementById('hero-progress-glow');
  const heroPct       = document.querySelector('.hero-progress-pct');
  if (hstatUnlocked) hstatUnlocked.textContent = String(data.totalUnlocked);
  if (hstatPoints)   hstatPoints.textContent   = String(data.totalPoints);
  if (heroFill) {
    const pct = Math.round((data.totalUnlocked / data.totalAchievements) * 100);
    heroFill.style.width = `${pct}%`;
    if (heroGlow)  (heroGlow as HTMLElement).style.left = `${pct}%`;
    if (heroPct)   heroPct.textContent = `${pct}%`;
  }
}

const initialize = () => {
  document.querySelectorAll<HTMLButtonElement>('.filter-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-pill').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      currentCat = btn.dataset.cat ?? 'all';
      renderGrid();
    });
  });

  document.getElementById('ach-search')?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value.trim();
    renderGrid();
  });

  document.getElementById('ach-sort')?.addEventListener('change', (e) => {
    currentSort = (e.target as HTMLSelectElement).value;
    renderGrid();
  });

  document.getElementById('view-grid')?.addEventListener('click', () => {
    viewMode = 'grid';
    const grid = document.getElementById('ach-grid')!;
    grid.classList.remove('list-view');
    document.getElementById('view-grid')!.classList.add('active');
    document.getElementById('view-list')!.classList.remove('active');
    renderGrid();
  });

  document.getElementById('view-list')?.addEventListener('click', () => {
    viewMode = 'list';
    const grid = document.getElementById('ach-grid')!;
    grid.classList.add('list-view');
    document.getElementById('view-list')!.classList.add('active');
    document.getElementById('view-grid')!.classList.remove('active');
    renderGrid();
  });
};

async function loadAchievements() {
  try {
    const res = await fetch('/api/achievements', { credentials: 'include' });
    if (!res.ok) return;
    const data = await res.json();
    allBadges = data.achievements ?? [];
    updatePillCounts();
    updateSummaryBanner(data);
    renderGrid();
    if (data.newlyUnlocked?.length > 0) {
      await new Promise<void>(r => setTimeout(r, 700));
      for (const id of data.newlyUnlocked) {
        const b = allBadges.find(b => b.id === id);
        if (b && (window as any).queueAchievementToast) {
          (window as any).queueAchievementToast({
            name: b.name, desc: b.description, icon: b.icon,
            rarity: b.rarityLabel, color: b.rarityColor
          });
        }
      }
    }
  } catch (err) {
    console.error('[AchievementsPanel] load failed:', err);
  }
}

(window as any).loadAchievements = loadAchievements;

const boot = () => {
  initialize();
  loadAchievements();
};

document.addEventListener('astro:page-load', boot);
if (document.readyState === 'interactive' || document.readyState === 'complete') {
  boot();
}
</script>
