---
interface Props {
  slug: string;
}

const { slug } = Astro.props;
---

<div class="episode-rating-widget group" data-slug={slug}>
  <div class="rating-skeleton">
    <div class="skeleton-pill">
      <div class="shimmer-bar"></div>
    </div>
  </div>
  
  <div class="rating-content" style="display: none;">
    <div class="stars-container">
      <div class="stars-row">
        {[1, 2, 3, 4, 5].map((i) => (
          <span class="star-display" data-index={i}>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="star-icon">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          </span>
        ))}
      </div>
    </div>
    
    <div class="rating-divider"></div>
    
    <div class="rating-data">
      <span class="rating-average">0.0</span>
      <span class="rating-count">0</span>
    </div>
  </div>
  
  <div class="rating-empty" style="display: none;">
    <div class="empty-stars">☆☆☆☆☆</div>
    <span class="no-rating-text">Sin valoraciones</span>
  </div>
</div>

<script>
  const initEpisodeRating = async () => {
    const widgets = document.querySelectorAll('.episode-rating-widget:not([data-loaded="true"])');
    if (widgets.length === 0) return;

    const slugs = Array.from(widgets).map(w => w.getAttribute('data-slug')).filter(Boolean);

    try {
      const res = await fetch('/api/ratings/bulk', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slugs })
      });
      const json = await res.json();

      if (json.success) {
        const data = json.data;
        widgets.forEach((widget) => {
          const slug = widget.getAttribute('data-slug');
          
          const skeleton = widget.querySelector('.rating-skeleton') as HTMLElement;
          const content = widget.querySelector('.rating-content') as HTMLElement;
          const empty = widget.querySelector('.rating-empty') as HTMLElement;
          
          if (!slug || !data[slug]) {
             if (skeleton) skeleton.style.display = 'none';
             if (empty) empty.style.display = 'flex';
             return;
          }

          const ratingData = data[slug];

          if (ratingData.count > 0) {
            const { average, count } = ratingData;
            
            // Update stars
            const stars = widget.querySelectorAll('.star-display');
            const rounded = Math.round(average);
            stars.forEach((star) => {
              const index = parseInt(star.getAttribute('data-index') || '0', 10);
              const svg = star.querySelector('svg');
              if (index <= rounded) {
                if (svg) {
                  svg.style.fill = '#f59e0b';
                  svg.style.stroke = '#f59e0b';
                }
                star.classList.add('filled');
              } else {
                if (svg) {
                  svg.style.fill = 'none';
                  svg.style.stroke = 'currentColor';
                }
                star.classList.remove('filled');
              }
            });

            // Update text
            const avgEl = widget.querySelector('.rating-average');
            const countEl = widget.querySelector('.rating-count');
            if (avgEl) avgEl.textContent = average.toFixed(1);
            if (countEl) countEl.textContent = count.toString();

            // Show content
            if (skeleton) skeleton.style.display = 'none';
            if (content) content.style.display = 'flex';
            if (empty) empty.style.display = 'none';
            widget.setAttribute('data-loaded', 'true');
          } else {
            // No ratings
            if (skeleton) skeleton.style.display = 'none';
            if (empty) empty.style.display = 'flex';
            if (content) content.style.display = 'none';
            widget.setAttribute('data-loaded', 'true');
          }
        });
      } else {
        throw new Error(json.error || 'API error');
      }
    } catch (e) {
      console.error("Bulk ratings load failed", e);
      widgets.forEach(w => {
        const skel = w.querySelector('.rating-skeleton') as HTMLElement;
        const emp = w.querySelector('.rating-empty') as HTMLElement;
        if (skel) skel.style.display = 'none';
        if (emp) {
            emp.style.display = 'flex';
            const txt = emp.querySelector('.no-rating-text');
            if (txt) txt.textContent = 'Error';
        }
      });
    }
  };

  // Run on initial load and on page transitions
  document.addEventListener('DOMContentLoaded', initEpisodeRating);
  document.addEventListener('astro:page-load', initEpisodeRating);
</script>

<style>
  .episode-rating-widget {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.875rem;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    min-height: 48px;
  }

  .episode-rating-widget:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
    transform: translateY(-1px);
    box-shadow: 0 10px 20px -10px rgba(0, 0, 0, 0.5);
  }

  /* Skeleton */
  .rating-skeleton {
    display: flex;
    align-items: center;
    width: 140px;
  }

  .skeleton-pill {
    width: 100%;
    height: 12px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 6px;
    overflow: hidden;
    position: relative;
  }

  .shimmer-bar {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.08), transparent);
    transform: translateX(-100%);
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    100% { transform: translateX(100%); }
  }

  /* Content */
  .rating-content {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .stars-row {
    display: flex;
    gap: 0.25rem;
    color: rgba(255, 255, 255, 0.1);
  }

  .star-icon {
    transition: all 0.4s ease;
  }

  .star-display.filled {
    color: #f59e0b;
    filter: drop-shadow(0 0 5px rgba(245, 158, 11, 0.3));
    transform: scale(1.1);
  }

  .rating-divider {
    width: 1px;
    height: 20px;
    background: rgba(255, 255, 255, 0.1);
  }

  .rating-data {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .rating-average {
    font-size: 1.125rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }

  .rating-count {
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.05);
    padding: 2px 6px;
    border-radius: 6px;
    min-width: 1.5rem;
    text-align: center;
  }

  /* Empty state */
  .rating-empty {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .empty-stars {
    letter-spacing: 2px;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.1);
  }

  .no-rating-text {
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Responsive tweaks */
  @media (max-width: 480px) {
    .episode-rating-widget {
      padding: 0.375rem 0.75rem;
      gap: 0.5rem;
    }
    
    .rating-content {
      gap: 0.5rem;
    }

    .stars-row {
      gap: 0;
    }

    .star-icon {
      width: 15px;
      height: 15px;
    }

    .rating-average {
      font-size: 1rem;
    }
  }

  [data-theme="light"] .episode-rating-widget {
    background: rgba(0, 0, 0, 0.02);
    border-color: rgba(0, 0, 0, 0.06);
  }

  [data-theme="light"] .rating-average {
    color: #1a1a2e;
  }

  [data-theme="light"] .rating-divider {
    background: rgba(0, 0, 0, 0.06);
  }

  [data-theme="light"] .rating-count {
    background: rgba(0, 0, 0, 0.04);
    color: rgba(0, 0, 0, 0.4);
  }

  [data-theme="light"] .stars-row {
    color: rgba(0, 0, 0, 0.08);
  }
</style>
