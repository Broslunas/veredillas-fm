---
import SidebarWidget from './SidebarWidget.astro';

interface Section {
  title: string;
  time: string; // "MM:SS"
}

interface Props {
  sections?: Section[];
  isPremiere?: boolean;
}

const { sections, isPremiere = false } = Astro.props;

if (!sections || sections.length === 0) {
  return;
}

// Convert "MM:SS" to seconds for data attribute
const parseTime = (t: string) => {
    const p = t.split(':').map(Number);
    if(p.length === 2) return p[0]*60 + p[1];
    if(p.length === 3) return p[0]*3600 + p[1]*60 + p[2];
    return 0;
};
---

<SidebarWidget title="Selector de Capítulos" isOpen={true}>
    <div class="relative px-2">
        <!-- Technical Vertical Line (Dashed) -->
        <div class="absolute left-6 top-6 bottom-6 w-px border-l border-dashed border-primary/30 z-0"></div>
        
        <ul class="sections-list relative z-10 flex flex-col gap-3 max-h-[480px] overflow-y-auto pr-2 scrollbar-none" data-is-premiere={isPremiere}>
            {sections.map((sec, index) => (
                <li class={`section-item relative flex items-center gap-3 ${isPremiere ? "premiere-hidden opacity-0 scale-95 pointer-events-none" : ""}`} style={isPremiere && index > 0 ? "display:none;" : ""}>
                    <!-- Numbered Marker (Smaller) -->
                    <div class="flex-shrink-0 relative z-10">
                        <div class="marker-box w-6 h-6 rounded border border-primary/20 bg-zinc-900/50 dark:bg-black/50 flex items-center justify-center transition-all duration-500 group-[.active]:border-primary group-[.active]:bg-primary group-[.active]:shadow-[0_0_10px_rgba(var(--color-primary-rgb,139,92,246),0.4)] group-[.active]:rotate-[360deg]">
                            <span class="text-[0.55rem] font-black text-primary/60 group-[.active]:text-white transition-colors">
                                {(index + 1).toString().padStart(2, '0')}
                            </span>
                        </div>
                    </div>

                    <!-- Compact Content -->
                    <button 
                        class="section-trigger group flex-1 text-left focus:outline-none min-w-0" 
                        data-time={parseTime(sec.time)}
                    >
                        <div class="flex items-center justify-between gap-3 transition-all duration-300 group-hover:translate-x-1">
                            <h4 class="text-[0.85rem] leading-tight font-bold text-zinc-500 group-hover:text-zinc-200 dark:text-zinc-500 dark:group-hover:text-zinc-300 transition-colors group-[.active]:text-zinc-900 dark:group-[.active]:text-white truncate">
                                {sec.title}
                            </h4>
                            
                            <div class="flex items-center gap-3 flex-shrink-0">
                                <!-- Playing Status Badge -->
                                <div class="hidden group-[.active]:flex items-center gap-1 px-1.5 py-0.5 rounded-sm bg-primary/10 border border-primary/20">
                                    <span class="w-1 h-1 rounded-full bg-primary animate-ping"></span>
                                    <span class="text-[0.55rem] font-black text-primary uppercase tracking-tighter">Live</span>
                                </div>
                                
                                <span class="font-mono text-[0.65rem] font-bold text-primary group-[.active]:animate-pulse bg-primary/5 px-1 rounded border border-primary/10">
                                    {sec.time}
                                </span>
                            </div>
                        </div>
                        <!-- Progress Underline (Subtle) -->
                        <div class="h-[1px] w-0 bg-primary/30 group-[.active]:w-full transition-all duration-700 ease-out mt-1"></div>
                    </button>
                </li>
            ))}
        </ul>
    </div>
</SidebarWidget>

<script>
    function initSections() {
        const list = document.querySelector('.sections-list') as HTMLElement;
        if (!list) return;
        
        const isPremiere = list.getAttribute('data-is-premiere') === 'true';
        const btns = document.querySelectorAll('.section-trigger');
        
        btns.forEach(btn => {
            btn.addEventListener('click', () => {
                const time = Number(btn.getAttribute('data-time'));
                if(!isNaN(time)) {
                    document.dispatchEvent(new CustomEvent('veredillas:audio-seek', {
                        detail: { time }
                    }));
                }
            });
        });
        
        document.addEventListener('veredillas:audio-timeupdate', (e: Event) => {
            const customEvent = e as CustomEvent;
            const currentTime = customEvent.detail.currentTime;
            const btnsArray = Array.from(document.querySelectorAll('.section-trigger'));
            let activeIdx = -1;

            if (isPremiere) {
                const items = document.querySelectorAll('.section-item');
                items.forEach(item => {
                   if (item.classList.contains('premiere-hidden')) {
                       const btn = item.querySelector('.section-trigger');
                       if (btn) {
                           const time = Number(btn.getAttribute('data-time'));
                           if (currentTime >= time) {
                               (item as HTMLElement).style.display = 'flex';
                               requestAnimationFrame(() => {
                                   item.classList.remove('premiere-hidden', 'opacity-0', 'scale-95', 'pointer-events-none');
                                   item.classList.add('reveal-anim');
                               });
                           }
                       }
                   }
                });
            }

            for (let i = 0; i < btnsArray.length; i++) {
                const time = Number(btnsArray[i].getAttribute('data-time'));
                const nextTime = btnsArray[i+1] ? Number(btnsArray[i+1].getAttribute('data-time')) : Infinity;
                if (currentTime >= time && currentTime < nextTime) {
                    activeIdx = i;
                    break;
                }
            }

            btnsArray.forEach((btn, idx) => {
                const listItem = btn.closest('.section-item');
                if (idx === activeIdx) btn.classList.add('active');
                else btn.classList.remove('active');
            });
        });
    }

    document.addEventListener('DOMContentLoaded', initSections);
    document.addEventListener('astro:page-load', initSections);
</script>

<style>
    @keyframes progress-slide {
        from { transform: translateX(-100%); }
        to { transform: translateX(300%); }
    }
    
    .reveal-anim {
        animation: reveal 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    @keyframes reveal {
        from { opacity: 0; transform: scale(0.9) translateY(10px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }

    /* Hide scrollbar but keep functionality */
    .scrollbar-none::-webkit-scrollbar {
        display: none;
    }
    .scrollbar-none {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>


