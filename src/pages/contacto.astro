---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contáctanos"
  description="¿Tienes alguna pregunta o sugerencia? Ponte en contacto con el equipo de Veredillas FM. Nos encantaría escucharte y conocer tus ideas."
  image="/logo.webp"
  imageAlt="Contacto"
  tags={['contacto', 'IES Veredillas', 'podcast', 'formulario de contacto']}
>
  <!-- Background Decor -->
  <div class="fixed inset-0 overflow-hidden pointer-events-none -z-10">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="grid-overlay"></div>
  </div>

  <section class="contact-section">
    <div class="container">
      <div class="contact-header gs-reveal">
        <div class="header-badge">
            <span class="live-dot"></span>
            <span>Siempre conectados</span>
        </div>
        <h1 class="hero-title">
            <span class="text-gradient">Habla</span> con nosotros
        </h1>
        <p class="subtitle">¿Tienes una idea, quieres participar o simplemente saludarnos? El micrófono está abierto para ti.</p>
      </div>

      <div class="contact-grid">
        <!-- Contact Info Side -->
        <div class="contact-info gs-reveal">
          <div class="info-card glass-panel">
            <div class="info-item">
              <div class="info-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
              </div>
              <div class="info-content">
                <h3>Instagram</h3>
                <a href="https://instagram.com/veredillasfm.es" target="_blank" class="email-link">@veredillasfm.es</a>
                <span class="info-hint">Mensajes directos abiertos</span>
              </div>
            </div>

            <div class="info-item">
              <div class="info-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div class="info-content">
                <h3>Email Oficial</h3>
                <a href="mailto:contacto@veredillasfm.es" class="email-link">contacto@veredillasfm.es</a>
                <span class="info-hint">Respondemos en 24h</span>
              </div>
            </div>

            <div class="info-item">
              <div class="info-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="info-content">
                <h3>Estudio</h3>
                <p>IES Las Veredillas</p>
                <span class="info-hint">Santa Cruz de Tenerife, Canarias</span>
              </div>
            </div>

            <div class="social-links">
                <p class="social-title">Síguenos comunitariamente</p>
                <div class="social-icons">
                    <a href="https://instagram.com/veredillasfm.es" target="_blank" class="social-icon" aria-label="Instagram">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
                    </a>
                    <a href="https://www.tiktok.com/@veredillas.fm" target="_blank" class="social-icon" aria-label="TikTok">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/></svg>
                    </a>
                    <a href="https://open.spotify.com/show/6mXWyLhzhET5EHk1p72j18" target="_blank" class="social-icon" aria-label="Spotify">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
                    </a>
                </div>
            </div>
          </div>
        </div>

        <!-- Contact Form Side -->
        <div class="form-wrapper gs-reveal fade-in-up delay-1">
          <form class="contact-form glass-panel" id="contactForm">
            <div class="form-row">
              <div class="form-group input-effect">
                <input type="text" id="name" name="name" placeholder=" " required />
                <label for="name">Nombre *</label>
                <div class="focus-border"></div>
              </div>
              
              <div class="form-group input-effect">
                <input type="email" id="email" name="email" placeholder=" " required />
                <label for="email">Email *</label>
                <div class="focus-border"></div>
              </div>
            </div>

            <div class="form-group input-effect">
              <input type="tel" id="phone" name="phone" placeholder=" " />
              <label for="phone">Teléfono (Opcional)</label>
              <div class="focus-border"></div>
            </div>

            <div class="form-group input-effect">
              <input type="text" id="subject" name="subject" placeholder=" " required />
              <label for="subject">Asunto *</label>
              <div class="focus-border"></div>
            </div>

            <div class="form-group input-effect">
              <textarea id="message" name="message" rows="5" placeholder=" " required></textarea>
              <label for="message">Mensaje *</label>
              <div class="focus-border"></div>
            </div>

            <button type="submit" class="btn btn-primary btn-lg submit-btn shine-effect">
              <span class="btn-text">
                  Envíar Mensaje
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 8px; display: inline-block; vertical-align: middle;"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              </span>
              <span class="btn-loader" style="display: none;">
                <svg class="spinner" viewBox="0 0 50 50"><circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle></svg>
              </span>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { gsap } from "gsap";
    
    document.addEventListener('DOMContentLoaded', () => {
        // Blob Animations
        if (document.querySelector(".blob")) {
            gsap.to(".blob-1", {
                y: 50,
                x: 30,
                duration: 4,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut"
            });

            gsap.to(".blob-2", {
                y: -60,
                x: -40,
                duration: 5,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut"
            });
        }

        // Reveal Animations
        if (document.querySelector(".gs-reveal")) {
            gsap.from(".gs-reveal", {
                y: 40,
                opacity: 0,
                duration: 0.8,
                stagger: 0.2,
                ease: "power3.out"
            });
        }
    });

    const form = document.getElementById('contactForm') as HTMLFormElement;
    const submitBtn = form?.querySelector('.submit-btn') as HTMLButtonElement;
    const btnText = submitBtn?.querySelector('.btn-text') as HTMLElement;
    const btnLoader = submitBtn?.querySelector('.btn-loader') as HTMLElement;

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (!submitBtn || !btnText || !btnLoader) return;
        
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        
        // Lock UI
        const inputs = form.querySelectorAll('input, textarea');
        inputs.forEach(input => (input as HTMLInputElement).disabled = true);
        submitBtn.disabled = true;
        btnText.style.display = 'none';
        btnLoader.style.display = 'inline-block';

        // GSAP submit animation
        gsap.to(submitBtn, { scale: 0.95, duration: 0.2 });

        try {
          const response = await fetch('/api/contact', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(data)
          });

          const result = await response.json();

          if (response.ok) {
            window.showToast('¡Mensaje enviado con éxito! Nos pondremos en contacto contigo pronto.', 'success');
            form.reset();
            // Optional: Success animation
            gsap.fromTo(form, { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.5, ease: "power2.out" });
          } else {
            window.showToast(result.message || 'Error al enviar el mensaje. Por favor intenta de nuevo.', 'error');
            // Shake animation on error
            gsap.fromTo(submitBtn, { x: -5 }, { x: 5, duration: 0.1, yoyo: true, repeat: 5 });
          }
        } catch (error) {
          console.error('Error:', error);
          window.showToast('Error de conexión. Por favor verifica tu internet e intenta de nuevo.', 'error');
           gsap.fromTo(submitBtn, { x: -5 }, { x: 5, duration: 0.1, yoyo: true, repeat: 5 });
        } finally {
          // Unlock UI
          inputs.forEach(input => (input as HTMLInputElement).disabled = false);
          submitBtn.disabled = false;
          btnText.style.display = 'inline-block';
          btnLoader.style.display = 'none';
          gsap.to(submitBtn, { scale: 1, duration: 0.2, ease: "back.out(1.7)" });
        }
      });
    }
  </script>
</Layout>

<style>
  /* Base & Background */
  .contact-section {
    padding: 6rem 0;
    min-height: calc(100vh - 100px);
    position: relative;
    overflow: hidden;
  }

  .blob {
      position: absolute;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.3;
  }
  
  .blob-1 {
      top: -10%;
      left: -10%;
      background: radial-gradient(circle, var(--color-primary), transparent 70%);
  }
  
  .blob-2 {
      bottom: -10%;
      right: -10%;
      background: radial-gradient(circle, var(--color-secondary), transparent 70%);
  }

  .grid-overlay {
      position: absolute;
      inset: 0;
      background-image: linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
      background-size: 50px 50px;
      mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
  }

  :global([data-theme="light"]) .grid-overlay {
      background-image: linear-gradient(rgba(0, 0, 0, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.04) 1px, transparent 1px);
  }

  /* Header */
  .contact-header {
      text-align: center;
      margin-bottom: 4rem;
      position: relative;
      z-index: 10;
  }

  .header-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      background: rgba(139, 92, 246, 0.1);
      border: 1px solid rgba(139, 92, 246, 0.2);
      border-radius: 100px;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--color-primary);
  }

  .live-dot {
      width: 8px;
      height: 8px;
      background: var(--color-primary);
      border-radius: 50%;
      box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.7);
      animation: pulse-primary 2s infinite;
  }

  @keyframes pulse-primary {
      0% { box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.7); }
      70% { box-shadow: 0 0 0 10px rgba(139, 92, 246, 0); }
      100% { box-shadow: 0 0 0 0 rgba(139, 92, 246, 0); }
  }

  .hero-title {
      font-size: clamp(2.5rem, 6vw, 4rem);
      line-height: 1.1;
      font-weight: 800;
      margin-bottom: 1rem;
      letter-spacing: -0.03em;
  }

  .text-gradient {
        background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
  }

  .subtitle {
      font-size: 1.15rem;
      color: var(--color-text-muted);
      max-width: 600px;
      margin: 0 auto;
      line-height: 1.6;
  }

  /* Grid Layout */
  .contact-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      position: relative;
      z-index: 10;
  }

  @media (min-width: 960px) {
      .contact-grid {
          grid-template-columns: 1fr 1.5fr;
          gap: 3rem;
          align-items: flex-start;
      }
  }

  /* Info Side */
  .info-card {
      padding: 2.5rem;
      border-radius: 24px;
      height: 100%;
      display: flex;
      flex-direction: column;
      gap: 2rem;
  }

  .info-item {
      display: flex;
      gap: 1.25rem;
      align-items: flex-start;
  }

  .info-icon {
      width: 48px;
      height: 48px;
      background: rgba(139, 92, 246, 0.1);
      color: var(--color-primary);
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: all 0.3s ease;
  }

  .info-item:hover .info-icon {
      background: var(--color-primary);
      color: white;
      transform: scale(1.05) rotate(5deg);
      box-shadow: 0 10px 20px rgba(139, 92, 246, 0.3);
  }

  .info-content h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--color-text-main);
      margin-bottom: 0.25rem;
  }

  .info-content p, .email-link {
      font-size: 1.05rem;
      color: var(--color-text-muted);
      margin-bottom: 0.25rem;
      line-height: 1.4;
      display: block;
      text-decoration: none;
      transition: color 0.2s;
  }

  .email-link:hover {
      color: var(--color-primary);
  }

  .info-hint {
      font-size: 0.8rem;
      color: var(--color-text-dim);
      font-weight: 500;
  }

  .social-links {
      margin-top: auto;
      padding-top: 2rem;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  :global([data-theme="light"]) .social-links {
      border-top-color: rgba(0, 0, 0, 0.1);
  }

  .social-title {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--color-text-main);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 1rem;
  }

  .social-icons {
      display: flex;
      gap: 1rem;
  }

  .social-icon {
      width: 44px;
      height: 44px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-text-main);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  :global([data-theme="light"]) .social-icon {
      background: rgba(0, 0, 0, 0.03);
      border-color: rgba(0, 0, 0, 0.08);
      color: var(--color-text-muted);
  }

  .social-icon:hover {
      background: var(--color-primary);
      border-color: var(--color-primary);
      color: white;
      transform: translateY(-4px) scale(1.05);
      box-shadow: 0 10px 20px rgba(139, 92, 246, 0.3);
  }

  /* Form Side */
  .contact-form {
      padding: 2.5rem;
      border-radius: 24px;
  }

  .form-row {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
  }

  @media (min-width: 640px) {
      .form-row {
          grid-template-columns: 1fr 1fr;
      }
  }

  /* Modern Input Effect */
  .input-effect {
      position: relative;
      margin-bottom: 1.5rem;
  }

  .input-effect input, 
  .input-effect textarea {
      width: 100%;
      padding: 1rem 1.2rem;
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      color: var(--color-text-main);
      font-family: inherit;
      font-size: 1rem;
      transition: all 0.3s;
      outline: none;
      z-index: 2;
      position: relative;
  }
  
  :global([data-theme="light"]) .input-effect input, 
  :global([data-theme="light"]) .input-effect textarea {
      background: transparent;
      border: 1px solid rgba(0, 0, 0, 0.1);
      color: var(--color-text-main);
  }

  .input-effect textarea {
      resize: vertical;
      min-height: 120px;
  }

  .input-effect label {
      position: absolute;
      left: 1.2rem;
      top: 1rem;
      color: var(--color-text-muted);
      font-size: 1rem;
      transition: all 0.3s ease;
      pointer-events: none;
      z-index: 1;
      background: transparent;
  }

  .input-effect.has-content label,
  .input-effect input:focus ~ label,
  .input-effect input:not(:placeholder-shown) ~ label,
  .input-effect textarea:focus ~ label,
  .input-effect textarea:not(:placeholder-shown) ~ label {
      top: -0.6rem;
      left: 1rem;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--color-primary);
      padding: 0 0.4rem;
      z-index: 3;
      border-radius: 4px;
  }
  
  /* Fallback behavior if background logic goes weird for input labels 
     To ensure visibility over transparent borders */
  .glass-panel .input-effect input:focus ~ label,
  .glass-panel .input-effect textarea:focus ~ label,
  .glass-panel .input-effect input:not(:placeholder-shown) ~ label,
  .glass-panel .input-effect textarea:not(:placeholder-shown) ~ label {
        background: #111; /* Dark theme fallback */
  }

  :global([data-theme="light"]) .glass-panel .input-effect input:focus ~ label,
  :global([data-theme="light"]) .glass-panel .input-effect textarea:focus ~ label,
  :global([data-theme="light"]) .glass-panel .input-effect input:not(:placeholder-shown) ~ label,
  :global([data-theme="light"]) .glass-panel .input-effect textarea:not(:placeholder-shown) ~ label {
        background: #fff; /* Light theme fallback */
  }

  .input-effect input:focus, 
  .input-effect textarea:focus {
      border-color: var(--color-primary);
      box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.1);
      background: rgba(255, 255, 255, 0.02);
  }
  
  :global([data-theme="light"]) .input-effect input:focus, 
  :global([data-theme="light"]) .input-effect textarea:focus {
      background: rgba(0, 0, 0, 0.01);
  }

  .submit-btn {
      width: 100%;
      min-height: 56px;
      font-size: 1.1rem;
      margin-top: 1rem;
      border-radius: 12px;
  }

  /* Spinner Animation */
  .spinner {
      animation: rotate 2s linear infinite;
      width: 24px;
      height: 24px;
  }
  
  .spinner .path {
      stroke: currentColor;
      stroke-linecap: round;
      animation: dash 1.5s ease-in-out infinite;
  }
  
  @keyframes rotate {
      100% { transform: rotate(360deg); }
  }
  
  @keyframes dash {
      0% { stroke-dasharray: 1, 150; stroke-dashoffset: 0; }
      50% { stroke-dasharray: 90, 150; stroke-dashoffset: -35; }
      100% { stroke-dasharray: 90, 150; stroke-dashoffset: -124; }
  }

  /* Custom override to fix focus background label */
  .glass-panel {
      position: relative;
  }
</style>
