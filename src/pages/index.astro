---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
import PostCard from '../components/PostCard.astro';
import FeaturedSlider from '../components/FeaturedSlider.astro';
import Newsletter from '../components/Newsletter.astro';
import TopListenersWidget from '../components/TopListenersWidget.astro';
import TrendingEpisodes from '../components/TrendingEpisodes.astro';
import TopClipsWidget from '../components/TopClipsWidget.astro';
import { getCollection } from 'astro:content';
import 'swiper/css';
import 'swiper/css/navigation';
import 'swiper/css/pagination';

const allEpisodes = await getCollection('episodios');
const allPosts = await getCollection('blog');

// For SSG, we provide a wide pool of episodes. 
// The client will filter them accurately.
const sortedEpisodes = allEpisodes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Recent episodes pool (top 12)
const recentEpisodesPool = sortedEpisodes.slice(0, 12);
// Upcoming candidate pool (we take a few from the end of all to be safe)
const upcomingCandidatePool = allEpisodes
    .filter(ep => ep.data.pubDate > new Date())
    .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

const recentPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
---

<Layout 
	title="Inicio"
	description="Veredillas FM es el podcast oficial del IES Veredillas. Escucha entrevistas exclusivas, noticias del instituto, deportes, cultura y tecnología. Una radio estudiantil hecha por alumnos, para alumnos."
	image="/logo.webp"
	imageAlt="Veredillas FM - El podcast oficial del IES Veredillas donde los alumnos tienen voz"
	tags={['podcast', 'radio escolar', 'IES Veredillas', 'estudiantes', 'educación', 'entrevistas', 'noticias escolares']}
>
    <!-- Background Decor -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none -z-10">
        <div class="blob blob-1 absolute w-[600px] h-[600px] rounded-full blur-[80px] opacity-40 top-[-100px] left-[-100px] bg-[radial-gradient(circle,theme(colors.primary),transparent)] animate-blob-float"></div>
        <div class="blob blob-2 absolute w-[600px] h-[600px] rounded-full blur-[80px] opacity-40 bottom-[-100px] right-[-100px] bg-[radial-gradient(circle,theme(colors.secondary),transparent)] animate-blob-float-reverse"></div>
        <div class="grid-overlay absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[length:50px_50px] [mask-image:linear-gradient(to_bottom,black_40%,transparent_100%)]"></div>
    </div>

    <!-- Hero Section -->
    <section class="pt-4 pb-16 relative overflow-hidden md:py-16">
        <div class="container relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_1fr] gap-8 lg:gap-16 items-center text-center lg:text-left">
                <div class="hero-content">
                    <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-full mb-8 text-sm font-semibold text-primary gs-reveal">
                        <span class="w-2 h-2 bg-red-500 rounded-full shadow-[0_0_0_0_rgba(239,68,68,0.7)] animate-pulse"></span>
                        <span>En vivo desde el instituto</span>
                    </div>
                    
                    <h1 class="text-[clamp(2.5rem,8vw,5.5rem)] leading-[1.1] font-extrabold mb-6 tracking-tight gs-reveal">
                        <span class="block">Bienvenidos,</span>
                        <span class="block">a Veredillas FM</span>
                    </h1>
                    
                    <p class="text-lg md:text-xl text-zinc-400 max-w-[500px] mb-10 leading-relaxed mx-auto lg:mx-0 gs-reveal">
                        Donde te mantenemos al pendiente de los temas más candentes.
                    </p>
                    

                    <div class="flex flex-col sm:flex-row justify-center lg:justify-start gap-4 mb-12 flex-wrap gs-reveal">
                        <a href="#latest-episodes" class="px-8 py-4 text-lg btn btn-primary rounded-full shine-effect">
                            <span class="icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                            </span> Escuchar Ahora
                        </a>
                        <a href="/about" class="px-8 py-4 text-lg btn btn-outline rounded-full">
                            Conocer Más
                        </a>
                    </div>
                </div>                <div class="flex justify-center items-center [perspective:1000px] w-full py-8 hero-visual" id="hero-spotlight">
                    {sortedEpisodes.length > 0 ? (
                        <a id="hero-link" href={`/ep/${sortedEpisodes[0].slug}`} class="relative block w-full max-w-[400px] aspect-square mx-auto cursor-pointer decoration-0 group" aria-label={`Escuchar ${sortedEpisodes[0].data.title}`}>
                            <div class="absolute inset-[5%] bg-[#111] rounded-full bg-[repeating-radial-gradient(#111_0,#111_2px,#222_3px,#222_4px)] shadow-[0_10px_30px_rgba(0,0,0,0.5)] z-[1] flex items-center justify-center vinyl-record text-[0px]">.
                                <div class="w-[35%] h-[35%] bg-black rounded-full flex items-center justify-center border-2 border-white overflow-hidden">
                                    <img src="/logo.webp" alt="VFM" class="w-full h-full object-cover" />
                                </div>
                            </div>
                            <div class="absolute inset-0 bg-gradient-to-br from-[#0e0e11] to-black rounded-lg border border-white/10 z-[2] shadow-[0_20px_50px_rgba(0,0,0,0.5)] -rotate-3 overflow-hidden flex items-center justify-center transition-transform duration-500 group-hover:rotate-[-5deg] lg:group-hover:-translate-x-[40%]">
                                <img 
                                    id="hero-img"
                                    src={sortedEpisodes[0].data.image} 
                                    alt={sortedEpisodes[0].data.title}
                                    class="w-full h-full object-cover absolute inset-0 z-[1]"
                                    data-slug-name={sortedEpisodes[0].slug}
                                />
                                <div class="absolute inset-0 z-10 bg-black/40 flex flex-col justify-between items-center p-6">
                                    <div class="w-full text-center">
                                        <h3 id="hero-title" class="font-display text-lg font-extrabold text-white uppercase leading-tight [text-shadow:0_2px_4px_rgba(0,0,0,0.5)]">{sortedEpisodes[0].data.title}</h3>
                                    </div>
                                    <div class="flex gap-[3px] items-center h-[15%] pointer-events-none">
                                        <span class="w-1.5 h-full bg-white rounded-full animate-spectrum opacity-50"></span>
                                        <span class="w-1.5 h-full bg-white rounded-full animate-spectrum opacity-50 [animation-duration:0.8s]"></span>
                                        <span class="w-1.5 h-full bg-white rounded-full animate-spectrum opacity-50 [animation-duration:1.2s]"></span>
                                        <span class="w-1.5 h-full bg-white rounded-full animate-spectrum opacity-50 [animation-duration:0.9s]"></span>
                                        <span class="w-1.5 h-full bg-white rounded-full animate-spectrum opacity-50 [animation-duration:1.1s]"></span>
                                        <span class="w-1.5 h-full bg-white rounded-full animate-spectrum opacity-50 [animation-duration:1.3s]"></span>
                                        <span class="w-1.5 h-full bg-white rounded-full animate-spectrum opacity-50 [animation-duration:0.7s]"></span>
                                        <span class="w-1.5 h-full bg-white rounded-full animate-spectrum opacity-50 [animation-duration:1.4s]"></span>
                                        <span class="w-1.5 h-full bg-white rounded-full animate-spectrum opacity-50 [animation-duration:0.85s]"></span>
                                        <span class="w-1.5 h-full bg-white rounded-full animate-spectrum opacity-50 [animation-duration:1.15s]"></span>
                                    </div>
                                    <div class="w-full text-center">
                                        <time id="hero-date" class="text-xs font-semibold text-white/90 tracking-wider uppercase bg-black/30 px-3 py-1 rounded-full backdrop-blur-sm">
                                            {sortedEpisodes[0].data.pubDate.toLocaleDateString('es-ES', { 
                                                year: 'numeric', 
                                                month: 'long', 
                                                day: 'numeric' 
                                            })}
                                        </time>
                                    </div>
                                </div>
                            </div>
                        </a>
                    ) : (
                        <div class="relative block w-full max-w-[400px] aspect-square mx-auto">
                            <!-- Placeholder -->
                        </div>
                    )}
                </div>
v>
            </div>
        </div>
    </section>

    <!-- Featured Section with Grid -->
    <section class="container gs-fade-up -mt-16 mb-24 relative z-20">
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_350px] gap-8 items-stretch">
            <div class="min-w-0">
                <FeaturedSlider />
            </div>
            <div class="h-full relative z-10">
                <TopListenersWidget />
            </div>
        </div>
    </section>

    <!-- Top Clips Section -->
    <TopClipsWidget />

    <!-- Latest Episodes Slider -->
    <section id="latest-episodes" class="py-16 md:py-24 overflow-hidden">
        <div class="container">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gs-fade-up">
                <div>
                    <h2 class="text-4xl mb-2">Nuevos Lanzamientos</h2>
                    <p class="text-zinc-400 text-lg">Lo último que está sonando en los pasillos</p>
                </div>
                <div class="hidden sm:flex gap-4">
                    <button class="w-[50px] h-[50px] rounded-full border border-zinc-800 bg-[#0e0e11] text-white flex items-center justify-center cursor-pointer transition-all duration-300 text-xl hover:bg-primary hover:border-primary swiper-button-prev-custom" aria-label="Previous slide">←</button>
                    <button class="w-[50px] h-[50px] rounded-full border border-zinc-800 bg-[#0e0e11] text-white flex items-center justify-center cursor-pointer transition-all duration-300 text-xl hover:bg-primary hover:border-primary swiper-button-next-custom" aria-label="Next slide">→</button>
                </div>
            </div>

            <div class="swiper episodes-swiper gs-fade-up">
                <div class="swiper-wrapper" id="latest-episodes-wrapper">
                    {recentEpisodesPool.map((post, index) => (
                        <div class="swiper-slide episode-container" data-pub-date={post.data.pubDate.toISOString()}>
                            <EpisodeCard post={post} disableTransition={index === 0} />
                        </div>
                    ))}
                </div>
                <div class="swiper-pagination"></div>
            </div>
            
            <div class="text-center mt-12 gs-fade-up">
                <a href="/ep" class="btn btn-outline rounded-full">Ver todos los episodios</a>
            </div>
        </div>
    </section>

    <!-- Upcoming Episodes Slider (Conditional) -->
    {upcomingCandidatePool.length > 0 && (
        <section id="upcoming-episodes" class="py-16 md:py-24 overflow-hidden relative bg-purple-900/10">
            <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/20 pointer-events-none"></div>
            <div class="container relative z-10">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gs-fade-up">
                    <div>
                        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-purple-500/20 border border-purple-500/30 text-purple-300 text-xs font-bold uppercase tracking-wider mb-2">
                             <span class="relative flex h-2 w-2">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-purple-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-purple-500"></span>
                            </span>
                            Próximamente
                        </div>
                        <h2 class="text-4xl mb-2">Próximos Estrenos</h2>
                        <p class="text-zinc-400 text-lg">Lo que está por llegar a Veredillas FM</p>
                    </div>
                    <div class="hidden sm:flex gap-4">
                        <button class="w-[50px] h-[50px] rounded-full border border-zinc-800 bg-[#0e0e11] text-white flex items-center justify-center cursor-pointer transition-all duration-300 text-xl hover:bg-primary hover:border-primary swiper-button-prev-custom" aria-label="Previous slide">←</button>
                        <button class="w-[50px] h-[50px] rounded-full border border-zinc-800 bg-[#0e0e11] text-white flex items-center justify-center cursor-pointer transition-all duration-300 text-xl hover:bg-primary hover:border-primary swiper-button-next-custom" aria-label="Next slide">→</button>
                    </div>
                </div>

                <div class="swiper episodes-swiper gs-fade-up">
                    <div class="swiper-wrapper" id="upcoming-episodes-wrapper">
                        {upcomingCandidatePool.map((post) => (
                            <div class="swiper-slide episode-container" data-pub-date={post.data.pubDate.toISOString()}>
                                <EpisodeCard post={post} />
                            </div>
                        ))}
                    </div>
                    <div class="swiper-pagination"></div>
                </div>
            </div>
        </section>
    )}

    <!-- Trending Episodes (Most Listened) -->
    <TrendingEpisodes />

    <!-- Marquee Text -->
    <div class="py-8 bg-primary overflow-hidden -rotate-2 scale-105 my-16">
        <div class="whitespace-nowrap flex animate-marquee">
            <span class="text-2xl md:text-4xl font-black text-black pr-8 uppercase font-display">• ENTREVISTAS EXCLUSIVAS • NOTICIAS DEL INSTITUTO • DEPORTES • CULTURA • CIENCIA Y TECNOLOGÍA • VIDA ESTUDIANTIL • EVENTOS • ORIENTACIÓN ACADÉMICA • COMUNIDAD •</span>
            <span class="text-2xl md:text-4xl font-black text-black pr-8 uppercase font-display">• ENTREVISTAS EXCLUSIVAS • NOTICIAS DEL INSTITUTO • DEPORTES • CULTURA • CIENCIA Y TECNOLOGÍA • VIDA ESTUDIANTIL • EVENTOS • ORIENTACIÓN ACADÉMICA • COMUNIDAD •</span>
        </div>
    </div>

    <!-- Recent Posts Section -->
    <section class="py-16 md:py-24 bg-white/[0.02]">
        <div class="container">
             <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gs-fade-up">
                 <div>
                    <h2 class="text-4xl mb-2">Actualidad</h2>
                    <p class="text-zinc-400 text-lg">Lo último que pasa en el Veredillas</p>
                </div>
                <div class="mt-4 md:mt-0">
                     <a href="/blog" class="btn btn-outline">Leer el blog</a>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 gs-fade-up">
                {recentPosts.map(post => (
                    <PostCard post={post} />
                ))}
            </div>
        </div>
    </section>

    <!-- About Feature -->
    <section class="py-16 md:py-24">
        <div class="container">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                <div class="p-8 md:p-10 rounded-2xl text-left transition-transform duration-300 hover:-translate-y-2.5 glass-panel gs-scroll-left">
                    <span class="text-5xl block mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </span>
                    <h3 class="text-xl md:text-2xl mb-4 font-bold">Hecho por alumnos</h3>
                    <p class="text-zinc-400 leading-relaxed">Todo el contenido es producido, grabado y editado por nosotros. Aprendemos haciendo.</p>
                </div>
                <div class="p-8 md:p-10 rounded-2xl text-left transition-transform duration-300 hover:-translate-y-2.5 glass-panel gs-scroll-up">
                    <span class="text-5xl block mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    </span>
                    <h3 class="text-xl md:text-2xl mb-4 font-bold">Cromos Digitales</h3>
                    <p class="text-zinc-400 leading-relaxed">¡Colecciona cromos exclusivos de nuestros invitados escuchando las entrevistas!</p>
                </div>
                <div class="p-8 md:p-10 rounded-2xl text-left transition-transform duration-300 hover:-translate-y-2.5 glass-panel gs-scroll-up">
                    <span class="text-5xl block mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                    </span>
                    <h3 class="text-xl md:text-2xl mb-4 font-bold">Tecnología Punta</h3>
                    <p class="text-zinc-400 leading-relaxed">Utilizamos las últimas herramientas para llevar la radio escolar al siglo XXI.</p>
                </div>
                <div class="p-8 md:p-10 rounded-2xl text-left transition-transform duration-300 hover:-translate-y-2.5 glass-panel gs-scroll-right">
                    <span class="text-5xl block mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                    </span>
                    <h3 class="text-xl md:text-2xl mb-4 font-bold">Sin Fronteras</h3>
                    <p class="text-zinc-400 leading-relaxed">Llevamos la voz del Veredillas a todo el mundo a través del streaming digital.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Newsletter Section -->
    <Newsletter />

    <!-- CTA Final -->
    <section class="py-24 md:py-32 text-center bg-gradient-to-t from-primary/10 to-transparent final-cta">
        <div class="container">
            <div class="gs-scale-up cta-inner">
                <h2 class="text-3xl md:text-6xl mb-4 font-bold">¿Tienes algo que contar?</h2>
                <p class="text-lg md:text-xl text-zinc-400 mb-8 max-w-2xl mx-auto">El micrófono está abierto para ti. Únete al equipo de Veredillas FM o ven a contar tu historia.</p>
                <div class="flex justify-center gap-4">
                    <a href="/solicitar-entrevista" class="px-12 py-5 text-xl btn btn-primary rounded-full">Solicitar Entrevista</a>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import Swiper from 'swiper';
    import { Navigation, Pagination, Autoplay } from 'swiper/modules';

    gsap.registerPlugin(ScrollTrigger);

    function initPage() {
        // Parallax Background Effect
        if (document.querySelector(".blob")) {
            // Blob 1 - Moves slower
            gsap.to(".blob-1", {
                yPercent: 50,
                ease: "none",
                scrollTrigger: {
                    trigger: "body",
                    start: "top top",
                    end: "bottom bottom",
                    scrub: 1
                }
            });

            // Blob 2 - Moves differently
            gsap.to(".blob-2", {
                yPercent: -50,
                ease: "none",
                scrollTrigger: {
                    trigger: "body",
                    start: "top top",
                    end: "bottom bottom",
                    scrub: 1.5
                }
            });

             // Grid Overlay - Subtle movement
             gsap.to(".grid-overlay", {
                yPercent: 10,
                ease: "none",
                scrollTrigger: {
                    trigger: "body",
                    start: "top top",
                    end: "bottom bottom",
                    scrub: 1
                }
            });
        }

        // Hero Animations
        if (document.querySelector(".gs-reveal")) {
            const tl = gsap.timeline();

            tl.from(".gs-reveal", {
                y: 50,
                opacity: 0,
                duration: 1,
                stagger: 0.2,
                ease: "power3.out"
            })
            .from(".hero-visual", {
                x: 50,
                opacity: 0,
                duration: 1,
                stagger: 0.2,
                ease: "back.out(1.7)"
            }, "-=0.5");
        }

        // Vinyl Rotation
        if (document.querySelector(".vinyl-record")) {
            gsap.to(".vinyl-record", {
                rotation: 360,
                duration: 10,
                repeat: -1,
                ease: "linear"
            });
        }

        // Stats Counter
        const stats = document.querySelectorAll('.stat-num');
        if (stats.length > 0) {
            stats.forEach(stat => {
                const target = parseInt(stat.getAttribute('data-count') || "0");
                gsap.to(stat, {
                    innerText: target,
                    duration: 2,
                    snap: { innerText: 1 },
                    ease: "power2.out"
                });
            });
        }

        // Scroll Animations
        gsap.utils.toArray('.gs-fade-up').forEach((elem: any) => {
            gsap.from(elem, {
                scrollTrigger: {
                    trigger: elem,
                    start: "top 85%",
                },
                y: 50,
                opacity: 0,
                duration: 0.8,
                ease: "power2.out"
            });
        });

        if (document.querySelector(".info-grid")) {
            gsap.from(".gs-scroll-left", {
                scrollTrigger: { trigger: ".info-grid", start: "top 80%" },
                x: -50, opacity: 0, duration: 0.8
            });
            
            gsap.from(".gs-scroll-up", {
                scrollTrigger: { trigger: ".info-grid", start: "top 80%" },
                y: 50, opacity: 0, duration: 0.8, delay: 0.2
            });

            gsap.from(".gs-scroll-right", {
                scrollTrigger: { trigger: ".info-grid", start: "top 80%" },
                x: 50, opacity: 0, duration: 0.8, delay: 0.4
            });
        }

        if (document.querySelector(".final-cta")) {
            gsap.from(".cta-inner", {
                scrollTrigger: { trigger: ".final-cta", start: "top 85%" },
                scale: 0.9,
                opacity: 0,
                duration: 0.6,
                ease: "back.out(1.7)"
            });
        }

        // Dynamic Reshuffle (SSG hydration)
        const now = new Date();
        const allEpisodeSlides = document.querySelectorAll('.episode-container');
        const latestWrapper = document.getElementById('latest-episodes-wrapper');
        const upcomingWrapper = document.getElementById('upcoming-episodes-wrapper');
        const upcomingSection = document.getElementById('upcoming-episodes');
        
        const publishedPool: HTMLElement[] = [];
        const upcomingPool: HTMLElement[] = [];

        allEpisodeSlides.forEach((slideNode) => {
            const slide = slideNode as HTMLElement;
            const pubDateStr = slide.dataset.pubDate;
            if (!pubDateStr) return;
            
            const pubDate = new Date(pubDateStr);
            const badge = slide.querySelector('.dynamic-upcoming-badge');
            const badgeText = badge?.querySelector('.badge-text');
            
            if (pubDate > now) {
                upcomingPool.push(slide);
                if (badge) {
                    badge.classList.remove('hidden');
                    
                    // Update about to premiere status
                    const diffHours = (pubDate.getTime() - now.getTime()) / (1000 * 60 * 60);
                    if (diffHours <= 2 && badgeText) {
                        badgeText.textContent = '¡Falta muy poco!';
                        badge.classList.remove('bg-primary/90', 'shadow-primary/30');
                        badge.classList.add('bg-red-600/90', 'shadow-red-600/30');
                    }
                }
            } else {
                publishedPool.push(slide);
                if (badge) badge.classList.add('hidden');
                slide.classList.remove('opacity-90');
            }
        });

        // Update Hero Spotlight with REAL latest published
        const realLatest = publishedPool.length > 0 ? publishedPool[0] : null;
        const heroSection = document.getElementById('hero-spotlight');
        if (realLatest && heroSection) {
            const title = realLatest.querySelector('h3')?.textContent || "";
            const img = (realLatest.querySelector('img') as HTMLImageElement | null)?.src || "";
            const href = (realLatest.querySelector('a') as HTMLAnchorElement | null)?.href || "";
            const slug = href.split('/ep/')[1] || "";
            const date = realLatest.querySelector('time')?.textContent || "";

            const heroTitle = document.getElementById('hero-title');
            const heroImg = document.getElementById('hero-img') as HTMLImageElement | null;
            const heroLink = document.getElementById('hero-link') as HTMLAnchorElement | null;
            const heroDate = document.getElementById('hero-date');

            if (heroTitle) heroTitle.textContent = title;
            if (heroImg && img) heroImg.src = img;
            if (heroLink && slug) {
                heroLink.href = `/ep/${slug}`;
                heroLink.setAttribute('aria-label', `Escuchar ${title}`);
            }
            if (heroDate) heroDate.textContent = date;
        }

        // Re-distribute nodes
        if (latestWrapper) {
            latestWrapper.innerHTML = '';
            publishedPool.slice(0, 8).forEach(el => latestWrapper.appendChild(el));
        }
        
        if (upcomingWrapper) {
            upcomingWrapper.innerHTML = '';
            upcomingPool.forEach(el => upcomingWrapper.appendChild(el));
            
            if (upcomingPool.length === 0 && upcomingSection) {
                upcomingSection.classList.add('hidden');
            } else if (upcomingSection) {
                upcomingSection.classList.remove('hidden');
            }
        }

        // Swiper Init (Scoped for multiple sliders)
        const swipers = document.querySelectorAll('.episodes-swiper');
        swipers.forEach(swiperNode => {
            const swiperEl = swiperNode as HTMLElement;
            // Find controls within the same section parent
            const section = swiperEl.closest('section');
            const nextEl = section?.querySelector('.swiper-button-next-custom');
            const prevEl = section?.querySelector('.swiper-button-prev-custom');

            new Swiper(swiperEl, {
                modules: [Navigation, Pagination, Autoplay],
                observer: true,
                observeParents: true,
                slidesPerView: 1,
                spaceBetween: 20,
                // Loop only if enough slides
                loop: swiperEl.querySelectorAll('.swiper-slide').length > 3,
                autoplay: {
                    delay: 5000,
                    disableOnInteraction: false,
                },
                pagination: {
                    el: swiperEl.querySelector('.swiper-pagination') as HTMLElement,
                    clickable: true,
                },
                navigation: {
                    nextEl: nextEl as HTMLElement,
                    prevEl: prevEl as HTMLElement,
                },
                breakpoints: {
                    640: {
                        slidesPerView: 2,
                        spaceBetween: 20,
                    },
                    1024: {
                        slidesPerView: 3,
                        spaceBetween: 30,
                    },
                    1280: {
                        slidesPerView: 3.5,
                        spaceBetween: 30,
                    }
                },
            });
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
            initPage();
        });
    } else {
        initPage();
    }
    
    // Cleanup for Astro view transitions if used later
    document.addEventListener('astro:after-swap', initPage);
</script>


