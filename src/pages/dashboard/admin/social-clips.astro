---
import Layout from '../../../layouts/Layout.astro';
import AdminNav from '../../../components/admin/AdminNav.astro';
import { getUserFromCookie } from '../../../lib/auth';
import User from '../../../models/User';
import dbConnect from '../../../lib/mongodb';

export const prerender = false;

const cookieHeader = Astro.request.headers.get('cookie');
const userPayload = getUserFromCookie(cookieHeader);

if (!userPayload) {
  return Astro.redirect('/404');
}

await dbConnect();

const currentUser = await User.findById(userPayload.userId);
if (!currentUser || (currentUser.role !== 'admin' && currentUser.role !== 'owner')) {
  return Astro.redirect('/404'); 
}

const N8N_WEBHOOK_URL = "https://n8n.broslunas.com/webhook/clips-upload-vfm";
const WEBHOOK_SECRET = import.meta.env.CONTACT_WEBHOOK_SECRET;
const DRIVE_FOLDER_ID = "1Bbc-VKX-k5ndMGKp2X05wdDQNk5I5LE7";
---

<Layout title="Social Clips Manager" robots="noindex, nofollow">
  <div class="fixed inset-0 overflow-hidden pointer-events-none -z-10 bg-slate-950">
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-violet-600/20 rounded-full blur-[120px]"></div>
    <div class="absolute -bottom-40 -right-40 w-96 h-96 bg-fuchsia-600/20 rounded-full blur-[120px]"></div>
    <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 brightness-100 contrast-150"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 py-8">
    <AdminNav />

    <header class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
            <h1 class="text-5xl font-black tracking-tight text-white mb-2 italic">SOCIAL <span class="text-violet-500">CLIPS</span></h1>
            <p class="text-slate-400 text-lg font-medium">Asistente de carga secuencial inteligente.</p>
        </div>
        <div class="flex items-center gap-3 bg-slate-900/50 backdrop-blur-xl border border-white/5 px-6 py-3 rounded-2xl shadow-2xl">
            <span class="flex h-3 w-3 relative">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
            </span>
            <span class="text-emerald-400 font-bold text-sm tracking-widest uppercase">Drive Conectado</span>
        </div>
    </header>

    <main id="main-container" class="min-h-[500px]">
        <!-- Step 1: Initial Multi-Selection -->
        <div id="step-selection" class="fade-in">
            <div 
                id="drop-zone" 
                class="group relative h-[450px] flex flex-col items-center justify-center border-2 border-dashed border-white/10 hover:border-violet-500/50 rounded-[3rem] bg-white/[0.02] hover:bg-violet-500/[0.03] transition-all duration-700 cursor-pointer overflow-hidden backdrop-blur-sm"
            >
                <div class="absolute inset-0 bg-gradient-to-br from-violet-600/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                
                <div class="relative flex flex-col items-center text-center px-6">
                    <div class="w-24 h-24 mb-8 rounded-3xl bg-white/5 flex items-center justify-center group-hover:scale-110 group-hover:rotate-12 transition-all duration-500 border border-white/10 group-hover:bg-violet-500/20 group-hover:border-violet-500/30">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-violet-400 group-hover:text-white transition-colors"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                    </div>
                    <h2 class="text-3xl font-bold text-white mb-4">Selecciona tus videos</h2>
                    <p class="text-slate-400 mb-2 max-w-sm">Arrastra múltiples archivos para empezar a procesar secuencialmente.</p>
                    <span class="text-slate-600 text-xs font-mono uppercase tracking-[0.2em] bg-white/5 px-4 py-2 rounded-full border border-white/5 group-hover:border-violet-500/20 transition-all">Formatos: MP4, MOV, WEBM</span>
                </div>
                <input type="file" id="file-input" accept="video/*" multiple hidden />
            </div>
        </div>

        <!-- Step 2: Individual Processing (Wizard) -->
        <div id="step-wizard" class="hidden grid grid-cols-1 lg:grid-cols-12 gap-10 fade-in">
            <!-- Left: Current Video Preview & Progress -->
            <div class="lg:col-span-12 xl:col-span-8 flex flex-col gap-6">
                <!-- Current File Status Banner -->
                <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-[2rem] p-4 flex items-center justify-between px-8">
                   <div class="flex items-center gap-4">
                        <div class="flex flex-col">
                            <span class="text-[10px] uppercase tracking-widest text-violet-400 font-bold">Procesando</span>
                            <h3 id="wizard-file-name" class="text-white font-bold text-lg truncate max-w-[300px]">video_archivo.mp4</h3>
                        </div>
                   </div>
                   <div class="flex items-center gap-3">
                        <span id="wizard-counter" class="bg-violet-600 text-white font-black px-4 py-1 rounded-xl text-sm">1 / 5</span>
                   </div>
                </div>

                <!-- Video Preview -->
                <div class="relative bg-black rounded-[3rem] overflow-hidden border border-white/10 aspect-video shadow-2xl group">
                    <video id="wizard-preview" controls class="w-full h-full object-contain"></video>
                    <!-- Progress Overlay during upload -->
                    <div id="upload-overlay" class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm flex flex-col items-center justify-center hidden z-20">
                        <div class="w-full max-w-md px-8 text-center">
                            <h4 id="overlay-status" class="text-2xl font-black italic text-white mb-8 tracking-tight">SUBIENDO ARCHIVO...</h4>
                            <div class="h-4 w-full bg-white/5 rounded-full overflow-hidden border border-white/10 relative">
                                <div id="overlay-bar" class="absolute left-0 top-0 h-full bg-gradient-to-r from-violet-600 via-fuchsia-500 to-indigo-500 rounded-full transition-all duration-300 transform-gpu" style="width: 0%">
                                    <div class="absolute inset-0 bg-[linear-gradient(45deg,rgba(255,255,255,0.2)_25%,transparent_25%,transparent_50%,rgba(255,255,255,0.2)_50%,rgba(255,255,255,0.2)_75%,transparent_75%,transparent)] bg-[length:24px_24px] animate-[slide_1s_linear_infinite]"></div>
                                </div>
                            </div>
                            <div class="flex justify-between mt-4 text-sm font-mono text-slate-400 italic">
                                <span id="overlay-bytes">0 MB / 15 MB</span>
                                <span id="overlay-percent">0%</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Metadata & Form -->
            <div class="lg:col-span-12 xl:col-span-4 flex flex-col gap-6">
                <div class="bg-white/5 backdrop-blur-3xl border border-white/10 p-8 rounded-[2.5rem] flex flex-col gap-8 shadow-2xl relative overflow-hidden group">
                    <div class="absolute -top-24 -right-24 w-48 h-48 bg-violet-600/10 rounded-full blur-3xl group-hover:bg-violet-600/20 transition-all duration-700"></div>

                    <div>
                        <h4 class="text-xs uppercase tracking-[0.2em] font-black text-slate-500 mb-6">Detalles del Video</h4>
                        
                        <div class="flex flex-col gap-2">
                            <label class="text-sm font-bold text-slate-300 ml-1">Título del Clip</label>
                            <input 
                                type="text" 
                                id="wizard-title" 
                                placeholder="Escribe un título descriptivo..." 
                                class="w-full bg-white/5 border border-white/10 rounded-2xl p-4 text-white focus:outline-none focus:ring-2 focus:ring-violet-500/50 transition-all placeholder:text-slate-600 font-medium"
                            />
                        </div>
                    </div>

                    <div class="mt-4 flex flex-col gap-4">
                        <button 
                            id="wizard-next-btn" 
                            class="w-full bg-white hover:bg-violet-50 text-slate-950 font-black py-5 rounded-2xl flex items-center justify-center gap-3 transition-all transform hover:scale-[1.02] active:scale-95 disabled:opacity-30 disabled:grayscale disabled:cursor-not-allowed group"
                            disabled
                        >
                            <span>SUBIR Y SIGUIENTE</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                        </button>
                        
                        <button id="wizard-cancel" class="text-slate-500 hover:text-rose-400 font-bold text-xs uppercase tracking-widest transition-colors py-2">Cancelar proceso</button>
                    </div>
                </div>

                <!-- Small Activity Log -->
                <div class="bg-slate-950/40 border border-white/5 rounded-[2rem] p-6 flex-1 overflow-hidden flex flex-col gap-4">
                    <h5 class="text-[10px] font-black text-slate-600 uppercase tracking-widest border-b border-white/5 pb-2">Actividad en tiempo real</h5>
                    <div id="wizard-log" class="flex flex-col gap-2 overflow-y-auto font-mono text-[11px] max-h-[150px]">
                        <div class="text-slate-500"><span class="text-violet-500">[*]</span> Sesión iniciada. Esperando datos...</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Step 3: Global Success -->
        <div id="step-success" class="hidden flex flex-col items-center justify-center text-center fade-in py-20">
            <div class="w-32 h-32 bg-emerald-500/20 rounded-full border border-emerald-500/30 flex items-center justify-center mb-8 animate-bounce">
                <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-500"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <h2 class="text-5xl font-black text-white italic mb-4">¡TODO LISTO!</h2>
            <p class="text-slate-400 text-lg mb-10 max-w-md">Todos los clips se han subido a Drive y n8n ha sido notificado.</p>
            <button onclick="location.reload()" class="bg-violet-600 hover:bg-violet-500 text-white font-black px-12 py-5 rounded-[2rem] shadow-2xl shadow-violet-500/20 transition-all hover:scale-105 active:scale-95 uppercase tracking-widest">Nueva carga</button>
        </div>
    </main>
  </div>
</Layout>

<script define:vars={{ WEBHOOK_URL: N8N_WEBHOOK_URL, WEBHOOK_SECRET: WEBHOOK_SECRET, FOLDER_ID: DRIVE_FOLDER_ID }}>
    let queue = [];
    let currentIndex = 0;

    // UI Elements
    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('file-input');
    const stepSelection = document.getElementById('step-selection');
    const stepWizard = document.getElementById('step-wizard');
    const stepSuccess = document.getElementById('step-success');
    
    // Wizard Control
    const wizardPreview = document.getElementById('wizard-preview');
    const wizardFileName = document.getElementById('wizard-file-name');
    const wizardCounter = document.getElementById('wizard-counter');
    const wizardTitle = document.getElementById('wizard-title');
    const wizardNextBtn = document.getElementById('wizard-next-btn');
    const wizardLog = document.getElementById('wizard-log');
    const wizardCancel = document.getElementById('wizard-cancel');

    // Upload Elements
    const uploadOverlay = document.getElementById('upload-overlay');
    const overlayBar = document.getElementById('overlay-bar');
    const overlayPercent = document.getElementById('overlay-percent');
    const overlayBytes = document.getElementById('overlay-bytes');
    const overlayStatus = document.getElementById('overlay-status');

    // Initialization
    dropZone.onclick = () => fileInput.click();
    fileInput.onchange = (e) => startWizard(e.target.files);

    function addLog(msg, color = 'text-slate-400') {
        const div = document.createElement('div');
        div.className = `${color}`;
        div.innerHTML = `<span class="text-violet-500">[*]</span> ${msg}`;
        wizardLog.prepend(div);
    }

    function formatBytes(bytes) {
        if (bytes === 0) return '0 Bytes';
        const k = 1024, sizes = ['Bytes', 'KB', 'MB', 'GB'], i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
    }

    // Step 1 -> Step 2
    function startWizard(files) {
        queue = Array.from(files).filter(f => f.type.startsWith('video/')).map(f => ({
            file: f,
            title: f.name.replace(/\.[^/.]+$/, ""),
            url: URL.createObjectURL(f)
        }));

        if (queue.length === 0) return;

        stepSelection.classList.add('hidden');
        stepWizard.classList.remove('hidden');
        loadCurrentStep();
    }

    function loadCurrentStep() {
        const item = queue[currentIndex];
        wizardPreview.src = item.url;
        wizardFileName.innerText = item.file.name;
        wizardCounter.innerText = `${currentIndex + 1} / ${queue.length}`;
        wizardTitle.value = item.title;
        wizardPreview.load();
        
        checkValidation();
        addLog(`Preparando clip ${currentIndex + 1}: ${item.file.name}`);
    }

    wizardTitle.oninput = checkValidation;

    function checkValidation() {
        wizardNextBtn.disabled = wizardTitle.value.trim().length === 0;
    }

    wizardCancel.onclick = () => {
        if (confirm('¿Seguro que quieres cancelar? Perderás el progreso actual.')) {
            location.reload();
        }
    };

    // Processing Logic
    wizardNextBtn.onclick = async () => {
        const item = queue[currentIndex];
        const currentTitle = wizardTitle.value.trim();
        
        wizardNextBtn.disabled = true;
        uploadOverlay.classList.remove('hidden');
        overlayStatus.innerText = 'OBTENIENDO LLAVE...';
        overlayBar.style.width = '0%';
        overlayPercent.innerText = '0%';
        
        addLog('Generando token de acceso...');

        try {
            // 1. Refresh Token Internal API
            const tokenRes = await fetch('/api/admin/drive-token');
            if (!tokenRes.ok) throw new Error('Error de seguridad interno.');
            const { access_token } = await tokenRes.json();

            addLog('Conexión con Drive abierta.');
            overlayStatus.innerText = 'INICIANDO SESIÓN...';

            // 2. Drive Resumable Session
            const metadata = { name: item.file.name, mimeType: item.file.type, parents: [FOLDER_ID] };
            const initRes = await fetch('https://www.googleapis.com/upload/drive/v3/files?uploadType=resumable', {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${access_token}`,
                    'X-Upload-Content-Type': item.file.type,
                    'X-Upload-Content-Length': item.file.size.toString(),
                    'Content-Type': 'application/json; charset=UTF-8',
                },
                body: JSON.stringify(metadata),
            });
            if (!initRes.ok) throw new Error('Drive rechazó la petición.');
            const uploadUrl = initRes.headers.get('Location');

            overlayStatus.innerText = 'SUBIENDO DATOS...';
            addLog(`Subiendo ${formatBytes(item.file.size)} directamente a Google...`);

            // 3. Real PUT with Progress
            const fileId = await new Promise((resolve, reject) => {
                const xhr = new XMLHttpRequest();
                xhr.open('PUT', uploadUrl, true);
                xhr.upload.onprogress = (e) => {
                    if (e.lengthComputable) {
                        const p = Math.round((e.loaded / e.total) * 100);
                        overlayBar.style.width = p + '%';
                        overlayPercent.innerText = p + '%';
                        overlayBytes.innerText = `${formatBytes(e.loaded)} / ${formatBytes(item.file.size)}`;
                    }
                };
                xhr.onload = () => (xhr.status === 200 || xhr.status === 201) ? resolve(JSON.parse(xhr.response).id) : reject(new Error('Drive upload failed'));
                xhr.onerror = () => reject(new Error('Conexión perdida.'));
                xhr.send(item.file);
            });

            addLog('Carga en Drive exitosa. Sincronizando n8n...', 'text-emerald-400');
            overlayStatus.innerText = 'NOTIFICANDO FLUJO...';

            // 4. Notify n8n
            const n8nRes = await fetch(WEBHOOK_URL, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${WEBHOOK_SECRET}` },
                body: JSON.stringify({
                    fileId,
                    title: currentTitle,
                    fileName: item.file.name,
                    timestamp: new Date().toISOString()
                })
            });
            
            if (!n8nRes.ok) throw new Error('n8n no respondió correctamente.');

            addLog(`¡Sincronizado! ${currentTitle} terminado.`, 'text-emerald-500');

            // --- MOVE NEXT ---
            currentIndex++;
            
            if (currentIndex < queue.length) {
                // Siguiente archivo
                setTimeout(() => {
                    uploadOverlay.classList.add('hidden');
                    loadCurrentStep();
                }, 1000);
            } else {
                // Finalizar todo
                setTimeout(() => {
                    stepWizard.classList.add('hidden');
                    stepSuccess.classList.remove('hidden');
                }, 1000);
            }

        } catch (error) {
            addLog(`ERROR: ${error.message}`, 'text-rose-500');
            overlayStatus.innerText = 'ERROR EN PROCESO';
            setTimeout(() => {
                uploadOverlay.classList.add('hidden');
                wizardNextBtn.disabled = false;
            }, 3000);
        }
    };
</script>

<style>
    @keyframes slide {
        from { background-position: 0 0; }
        to { background-position: 24px 0; }
    }
    
    .fade-in {
        animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px) scale(0.98); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* Custom scrollbar for log */
    #wizard-log::-webkit-scrollbar {
        width: 4px;
    }
    #wizard-log::-webkit-scrollbar-track {
        background: transparent;
    }
    #wizard-log::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.05);
        border-radius: 10px;
    }
</style>
