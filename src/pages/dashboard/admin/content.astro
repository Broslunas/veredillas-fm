---
import Layout from '../../../layouts/Layout.astro';
import AdminNav from '../../../components/admin/AdminNav.astro';
import { getUserFromCookie } from '../../../lib/auth';
import User from '../../../models/User';
import dbConnect from '../../../lib/mongodb';
import { getCollection } from 'astro:content';

export const prerender = false;

const cookieHeader = Astro.request.headers.get('cookie');
const userPayload = getUserFromCookie(cookieHeader);

if (!userPayload) {
  return Astro.redirect('/404');
}

await dbConnect();

const currentUser = await User.findById(userPayload.userId);
if (!currentUser || (currentUser.role !== 'admin' && currentUser.role !== 'owner')) {
  return Astro.redirect('/404'); 
}

// Fetch all users for stats aggregation
const users = await User.find({});

// Fetch Episodes
const allEpisodes = await getCollection('episodios');
const episodesMap = new Map(allEpisodes.map(e => [e.slug, e.data.title]));

// --- Stats Calculation ---
const episodeStats = new Map<string, { plays: number, completions: number, favorites: number }>();

// Initialize with 0 for all existing episodes
allEpisodes.forEach(ep => {
    episodeStats.set(ep.slug, { plays: 0, completions: 0, favorites: 0 });
});

users.forEach(u => {
    if (u.playbackHistory) {
         u.playbackHistory.forEach(h => {
             // Episode Stats
            const current = episodeStats.get(h.episodeSlug) || { plays: 0, completions: 0, favorites: 0 };
            current.plays += 1;
            if (h.completed) current.completions += 1;
            episodeStats.set(h.episodeSlug, current);
        });
    }

    if (u.favorites) {
        u.favorites.forEach(slug => {
            const current = episodeStats.get(slug) || { plays: 0, completions: 0, favorites: 0 };
            current.favorites += 1;
            episodeStats.set(slug, current);
        });
    }
});

const sortedEpisodeStats = Array.from(episodeStats.entries())
    .map(([slug, stats]) => ({
        slug,
        title: episodesMap.get(slug) || slug,
        ...stats
    }))
    .sort((a, b) => b.plays - a.plays);

const totalPlays = sortedEpisodeStats.reduce((acc, curr) => acc + curr.plays, 0);
const totalCompletions = sortedEpisodeStats.reduce((acc, curr) => acc + curr.completions, 0);
const totalFavorites = sortedEpisodeStats.reduce((acc, curr) => acc + curr.favorites, 0);
const avgRetention = totalPlays > 0 ? (totalCompletions / totalPlays) * 100 : 0;
const totalRegisteredUsers = users.length;

const topEpisode = sortedEpisodeStats[0];

---

<Layout title="Analíticas de Contenido - Admin" robots="noindex, nofollow">
    <!-- Background Effects -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none -z-10">
        <div class="absolute top-[10%] left-[20%] w-[40rem] h-[40rem] rounded-full bg-purple-600/10 blur-[120px] mix-blend-screen"></div>
        <div class="absolute bottom-[10%] right-[20%] w-[40rem] h-[40rem] rounded-full bg-indigo-600/10 blur-[120px] mix-blend-screen"></div>
        <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_50%,#000_30%,transparent_100%)] opacity-70"></div>
    </div>

    <div class="max-w-[1400px] mx-auto p-4 md:p-8 text-neutral-200 animate-fade-in-up transition-all duration-500">
        
        <!-- Header Section -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-10 gap-4">
            <div>
                <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight bg-gradient-to-r from-white via-purple-200 to-purple-400 bg-clip-text text-transparent mb-2">
                    Analíticas de Contenido
                </h1>
                <p class="text-neutral-400 text-lg">Métricas de rendimiento y reproducciones de tus episodios</p>
            </div>
            <a href="/dashboard/admin/cms/" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 text-white font-semibold rounded-xl shadow-[0_4px_20px_rgba(147,51,234,0.3)] hover:shadow-[0_8px_30px_rgba(147,51,234,0.5)] transition-all duration-300 hover:-translate-y-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                Abrir Creador de Contenido
            </a>
        </div>

        <div class="mb-10">
            <AdminNav />
        </div>

        <!-- Key Metrics Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
            <!-- Total Plays -->
            <div class="bg-white/[0.02] border border-white/10 rounded-3xl p-6 backdrop-blur-xl shadow-2xl relative overflow-hidden group hover:border-purple-500/30 transition-all duration-300">
                <div class="absolute inset-0 bg-gradient-to-br from-purple-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-neutral-400 font-medium">Reproducciones Totales</h3>
                    <div class="p-2.5 bg-purple-500/20 text-purple-400 rounded-xl">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                    </div>
                </div>
                <p class="text-4xl font-bold text-white tracking-tight">{totalPlays}</p>
            </div>

            <!-- Avg Retention -->
            <div class="bg-white/[0.02] border border-white/10 rounded-3xl p-6 backdrop-blur-xl shadow-2xl relative overflow-hidden group hover:border-blue-500/30 transition-all duration-300">
                <div class="absolute inset-0 bg-gradient-to-br from-blue-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-neutral-400 font-medium">Retención Promedio</h3>
                    <div class="p-2.5 bg-blue-500/20 text-blue-400 rounded-xl">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
                    </div>
                </div>
                <div class="flex items-end gap-2">
                    <p class="text-4xl font-bold text-white tracking-tight">{Math.round(avgRetention)}%</p>
                    <p class="text-sm text-neutral-400 mb-1.5 font-medium">completados</p>
                </div>
            </div>

            <!-- Total Favorites -->
            <div class="bg-white/[0.02] border border-white/10 rounded-3xl p-6 backdrop-blur-xl shadow-2xl relative overflow-hidden group hover:border-pink-500/30 transition-all duration-300">
                <div class="absolute inset-0 bg-gradient-to-br from-pink-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-neutral-400 font-medium">Favoritos Globales</h3>
                    <div class="p-2.5 bg-pink-500/20 text-pink-400 rounded-xl">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                    </div>
                </div>
                <p class="text-4xl font-bold text-white tracking-tight">{totalFavorites}</p>
            </div>

            <!-- Users Reach -->
            <div class="bg-white/[0.02] border border-white/10 rounded-3xl p-6 backdrop-blur-xl shadow-2xl relative overflow-hidden group hover:border-emerald-500/30 transition-all duration-300">
                <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-neutral-400 font-medium">Usuarios Registrados</h3>
                    <div class="p-2.5 bg-emerald-500/20 text-emerald-400 rounded-xl">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                    </div>
                </div>
                <p class="text-4xl font-bold text-white tracking-tight">{totalRegisteredUsers}</p>
            </div>
        </div>

        {topEpisode && topEpisode.plays > 0 && (
            <div class="mb-10 p-[1px] rounded-[2rem] bg-gradient-to-r from-purple-500/40 via-pink-500/40 to-blue-500/40 overflow-hidden shadow-2xl shadow-purple-500/10">
                <div class="bg-neutral-900/90 backdrop-blur-2xl rounded-[calc(2rem-1px)] p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-8 h-full">
                    <div class="flex items-center gap-6 w-full md:w-auto">
                        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center shrink-0 shadow-lg shadow-purple-500/30 border border-white/20 relative overflow-hidden">
                             <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="relative z-10"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                             <div class="absolute inset-0 bg-white/20 animate-pulse mix-blend-overlay"></div>
                        </div>
                        <div class="flex-1">
                            <p class="text-xs md:text-sm uppercase tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-400 font-bold mb-1">¡Episodio Más Exitoso!</p>
                            <h2 class="text-2xl md:text-3xl font-bold text-white leading-tight">{topEpisode.title}</h2>
                        </div>
                    </div>
                    <div class="flex items-center gap-6 md:gap-10 divide-x divide-white/10 w-full md:w-auto pb-2 md:pb-0 border-b border-white/10 md:border-none">
                        <div class="pl-0 md:px-0 flex-1 md:flex-none">
                            <p class="text-neutral-400 text-xs md:text-sm mb-1 uppercase tracking-wider font-semibold">Reproducciones</p>
                            <p class="text-3xl md:text-4xl font-bold text-white tracking-tight">{topEpisode.plays}</p>
                        </div>
                        <div class="pl-6 md:pl-10 flex-1 md:flex-none">
                            <p class="text-neutral-400 text-xs md:text-sm mb-1 uppercase tracking-wider font-semibold">Retención</p>
                            <p class="text-3xl md:text-4xl font-bold text-emerald-400 tracking-tight glow-emerald">{Math.round((topEpisode.completions / topEpisode.plays) * 100)}%</p>
                        </div>
                    </div>
                </div>
            </div>
        )}

        <!-- Data Table -->
        <div class="bg-white/[0.02] border border-white/10 rounded-3xl p-1 md:p-6 backdrop-blur-2xl shadow-2xl overflow-hidden relative">
            <div class="absolute inset-0 bg-gradient-to-b from-white/5 to-transparent pointer-events-none"></div>
            <div class="p-5 md:p-0 flex items-center justify-between mb-2 md:mb-6">
                <h2 class="text-xl md:text-2xl font-bold text-white relative z-10">Desglose por Episodio</h2>
                <div class="text-xs md:text-sm font-medium text-neutral-400 px-3 py-1 bg-white/5 rounded-full border border-white/10 relative z-10">Ordenado por reproducciones</div>
            </div>
            
            <div class="overflow-x-auto relative z-10 rounded-2xl">
                <table class="w-full text-left min-w-[700px] border-collapse">
                    <thead>
                        <tr class="border-b border-white/10 text-neutral-400 text-xs md:text-sm uppercase tracking-widest bg-white/[0.01]">
                            <th class="p-4 md:p-5 font-semibold">Episodio</th>
                            <th class="p-4 md:p-5 font-semibold text-center whitespace-nowrap">Reproducciones</th>
                            <th class="p-4 md:p-5 font-semibold text-center whitespace-nowrap">Completados</th>
                            <th class="p-4 md:p-5 font-semibold text-center whitespace-nowrap">Favoritos</th>
                            <th class="p-4 md:p-5 font-semibold w-64">Retención</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/[0.05]">
                        {sortedEpisodeStats.map((stat, i) => {
                            const rate = stat.plays > 0 ? (stat.completions / stat.plays) * 100 : 0;
                            return (
                                <tr class="hover:bg-white/[0.04] transition-all duration-200 group">
                                    <td class="p-4 md:p-5">
                                        <div class="flex items-center gap-4">
                                            <div class="w-8 h-8 md:w-10 md:h-10 rounded-full bg-white/5 flex items-center justify-center text-xs md:text-sm font-bold text-neutral-500 group-hover:bg-gradient-to-br group-hover:from-purple-500 group-hover:to-indigo-500 group-hover:text-white group-hover:shadow-[0_0_15px_rgba(147,51,234,0.4)] transition-all duration-300 border border-white/10 shrink-0">
                                                {i + 1}
                                            </div>
                                            <span class="font-medium text-white/90 group-hover:text-white transition-colors line-clamp-2 md:line-clamp-1">{stat.title}</span>
                                        </div>
                                    </td>
                                    <td class="p-4 md:p-5 text-center">
                                        <span class="inline-flex items-center justify-center px-4 py-1.5 rounded-full bg-white/5 text-neutral-200 font-mono text-sm md:text-base border border-white/5 group-hover:border-white/10 group-hover:bg-white/10 transition-colors shadow-inner">
                                            {stat.plays}
                                        </span>
                                    </td>
                                    <td class="p-4 md:p-5 text-center font-mono text-sm md:text-base text-neutral-300">
                                        {stat.completions}
                                    </td>
                                    <td class="p-4 md:p-5 text-center">
                                        <span class="inline-flex items-center justify-center gap-1.5 px-3 py-1 rounded-full text-pink-400 font-mono text-sm md:text-base group-hover:bg-pink-500/10 transition-colors">
                                            {stat.favorites > 0 ? (
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                                            ) : (
                                                 <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-30"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                                            )}
                                            {stat.favorites}
                                        </span>
                                    </td>
                                    <td class="p-4 md:p-5">
                                        <div class="flex flex-col gap-2">
                                            <div class="flex justify-between items-center relative">
                                                <span class="text-xs text-neutral-500 font-medium">Completados</span>
                                                <span class={`text-sm font-bold ${rate > 70 ? 'text-emerald-400' : rate > 40 ? 'text-amber-400' : 'text-rose-400'}`}>{Math.round(rate)}%</span>
                                            </div>
                                            <div class="w-full h-2.5 bg-black/40 rounded-full overflow-hidden border border-white/5 shadow-inner relative">
                                                <div 
                                                    class={`absolute top-0 left-0 h-full rounded-full transition-all duration-1000 ease-out ${rate > 70 ? 'bg-gradient-to-r from-emerald-500 to-emerald-400 shadow-[0_0_10px_rgba(16,185,129,0.5)]' : rate > 40 ? 'bg-gradient-to-r from-amber-500 to-amber-400 shadow-[0_0_10px_rgba(245,158,11,0.5)]' : 'bg-gradient-to-r from-rose-500 to-rose-400 shadow-[0_0_10px_rgba(244,63,94,0.5)]'}`}
                                                    style={`width: ${rate}%`}
                                                ></div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            );
                        })}
                    </tbody>
                </table>
            </div>
            {sortedEpisodeStats.length === 0 && (
                <div class="p-16 text-center text-neutral-500 flex flex-col items-center justify-center gap-4 relative z-10">
                    <div class="p-4 rounded-full bg-white/5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                    </div>
                    <p class="text-lg">Aún no hay datos de episodios disponibles.</p>
                </div>
            )}
        </div>
    </div>
</Layout>
